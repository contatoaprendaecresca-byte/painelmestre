/**
 * Menu.gs — ÚNICO onOpen / onInstall do projeto (centraliza tudo)
 * - Evita duplicidade de onOpen e menus espalhados
 * - Mantém os handlers existentes (Motor/Dashboard/Insights/Bagy)
 */

function onOpen(e){
  const ui = SpreadsheetApp.getUi();

  const root = ui.createMenu('📌 Mestre');

  // Setup / Config
  root
    .addItem('🧱 Criar / verificar estrutura (MESTRE + PROPRIEDADES)', 'bootstrap')
    .addItem('🔄 Sync PROPRIEDADES → Script Properties', 'syncPropsFromSheet')
    .addSeparator();

  // Motor (GA4 + Meta)
  const mMotor = ui.createMenu('⚙️ Motor (GA4 + Meta)');
  mMotor
    .addItem('⏱️ Atualizar últimos 3 dias (force)', 'runRecent3d')
    .addItem('⏱️ Atualizar últimos 5 dias (force)', 'runRecent5d')
    .addSeparator()
    .addItem('🗓️ Atualizar 1 dia específico…', 'runSingleDatePrompt')
    .addItem('🗓️↔️ Atualizar intervalo…', 'runRangePrompt')
    .addItem('🗓️➡️ Atualizar a partir de uma data… (até hoje)', 'runFromDatePrompt')
    .addSeparator()
    .addItem('🩹 Correção rápida: 23/12/2025 → hoje', 'runFixFrom_2025_12_23')
    .addSeparator()
    .addItem('🧨 Backfill desde START_DATE (pesado)', 'runBlocksFromScratch')
    .addSeparator()
    .addItem('⏰ Instalar trigger (a cada 6h) — últimos 3 dias', 'installRecent3dTrigger')
    .addItem('🧹 Remover trigger (runRecent3d)', 'uninstallRecent3dTrigger')
    .addItem('🧾 Listar triggers', 'menuListTriggers');
      // Semanal (novo — desempenho semanal)
  const mWeekly = ui.createMenu('📅 Semanal');
  mWeekly
    .addItem('📌 Gerar FULL desde 01/01/2026', 'WEEKLY_buildFullFrom_2026_01_01')
    .addItem('🔄 Atualizar últimas 12 semanas', 'WEEKLY_updateLast12Weeks')
    .addSeparator()
    .addItem('⏰ Instalar trigger semanal (seg 06:50)', 'WEEKLY_installWeeklyTrigger')
    .addItem('🧹 Remover trigger semanal', 'WEEKLY_removeWeeklyTrigger')
    .addItem('🧾 Ver triggers (Semanal)', 'WEEKLY_listWeeklyTriggers');

  root.addSubMenu(mWeekly);


  root.addSubMenu(mMotor);

  // Dashboard / WebApp
  const mDash = ui.createMenu('📊 Relatório (Dashboard)');
  mDash
    .addItem('🖥️ Abrir painel (escolher período)', 'showDashboard_')
    .addSeparator()
    .addItem('🧊 Cache: Setup (criar abas)', 'DASH_CACHE_SETUP')
    .addItem('🔁 Cache: Sync (janela 180d)', 'DASH_CACHE_SYNC')
    .addItem('🧱 Cache: Rebuild full (lento)', 'DASH_CACHE_REBUILD')
    .addItem('🔎 Cache: Status', 'DASH_CACHE_STATUS')
    .addSeparator()
    .addItem('⏰ Cache: Instalar trigger 06:00', 'DASH_CACHE_INSTALL_TRIGGER')
    .addItem('🧹 Cache: Remover trigger', 'DASH_CACHE_REMOVE_TRIGGER');

  root.addSubMenu(mDash);

   // Insight
  const mInsight = ui.createMenu('💡 Insight');
  mInsight
    .addItem('📌 Hoje vs ontem', 'insight_hojeVsOntem')
    .addSeparator()
    .addItem('📆 Últimos 3 dias (até ontem) vs 3 anteriores', 'insight_ultimos3Dias')
    .addItem('📆 Últimos 7 dias (até ontem) vs 7 anteriores', 'insight_ultimos7Dias')
    .addItem('📆 Últimos 14 dias (até ontem) vs 14 anteriores', 'insight_ultimos14Dias')
    .addItem('📆 Últimos 30 dias (até ontem) vs 30 anteriores', 'insight_ultimos30Dias')
    .addSeparator()
    .addItem('📝 Período manual (dd/mm/aaaa a dd/mm/aaaa)', 'insight_periodoManual')
    .addItem('🧠 Período manual + escolher comparativo', 'insight_periodoManual_comComparacao') // ✅ NOVO
    .addItem('🧠 Últimos 7 dias + escolher comparativo', 'insight_ultimos7Dias_comComparacao')
    .addSeparator()
    .addItem('⏰ Instalar gatilho semanal (segunda 06:45)', 'insight_instalarGatilhoSemanal')
    .addItem('🧹 Remover gatilho semanal', 'insight_removerGatilhoSemanal')
    .addItem('🧾 Ver gatilhos do insight', 'insight_listarGatilhos');


  root.addSubMenu(mInsight);

  // Bagy (visão)
  const mBagy = ui.createMenu('🛒 Bagy (visão)');
  mBagy
    .addItem('📈 Gerar MTD vs mês anterior (Bagy)', 'runBagyMTDOverview_')
    .addItem('🗓️ Gerar RESUMO_BAGY_MENSAL', 'buildBagyMonthlyRollup_')
    .addSeparator()
    .addItem('⏰ Criar gatilho diário 7h (MTD)', 'createBagyMTDTrigger_')
    .addItem('🧹 Remover gatilho 7h (MTD)', 'removeBagyMTDTrigger_');

  root.addSubMenu(mBagy);

  // Extra
  root
    .addSeparator()
    .addItem('🧾 Listar triggers do projeto', 'menuListTriggers');

  root.addToUi();
}

function onInstall(e){ onOpen(e); }

/** Lista triggers do projeto */
function menuListTriggers(){
  const triggers = ScriptApp.getProjectTriggers();
  const lines = triggers.map(t => {
    const src = (t.getTriggerSource && t.getTriggerSource()) || 'CLOCK';
    const et  = (t.getEventType && t.getEventType()) || 'TIME';
    return `• ${t.getHandlerFunction()} | ${src} | ${et}`;
  });
  const msg = lines.length ? lines.join('\n') : 'Nenhum trigger ativo.';
  SpreadsheetApp.getUi().alert('🧾 Triggers deste projeto:\n\n' + msg);
}

/** Remove o trigger que chama runRecent3d (caso exista) */
function uninstallRecent3dTrigger(){
  const fn = 'runRecent3d';
  const toDelete = ScriptApp.getProjectTriggers().filter(t => t.getHandlerFunction() === fn);
  toDelete.forEach(t => ScriptApp.deleteTrigger(t));
  SpreadsheetApp.getUi().alert(`🧹 Removidos ${toDelete.length} trigger(s) do handler "${fn}".`);
}
