/**
* @summary Converte dados de uma aba da planilha para um array de objetos JSON.
* @param {GoogleAppsScript.Spreadsheet.Sheet} sheet O objeto da aba da planilha.
* @returns {Array<Object>} Um array de objetos, onde cada objeto representa uma linha.
*/
function sheetToJSON(sheet) {
  if (!sheet) return [];
  const data = sheet.getDataRange().getValues();
  if (data.length < 2) return []; // Retorna vazio se não houver dados (só cabeçalho)

  const headers = data[0].map(header => header.toString().trim());
  return data.slice(1).map(row => {
    const rowData = {};
    headers.forEach((header, index) => {
      rowData[header] = row[index];
    });
    return rowData;
  });
}


/**
* @summary Converte uma string de data no formato DD/MM/YYYY para um objeto Date.
* @param {string|Date} dateString A string de data (ex: "23/01/2025") ou um objeto Date.
* @returns {Date|null} Um objeto Date ou null se for inválido.
*/
function parseBrazilianDate(dateString) {
  if (!dateString) return null;
  // Se já for um objeto Date (vem da planilha às vezes)
  if (Object.prototype.toString.call(dateString) === '[object Date]') {
    return dateString;
  }
  // Se for string
  if (typeof dateString === 'string') {
    let datePart = dateString.split('T')[0].split(' ')[0]; // Limpa horas

    const parts = datePart.split('/');
    if (parts.length === 3) {
      // Formato DD/MM/YYYY
      const day = parseInt(parts[0], 10);
      const month = parseInt(parts[1], 10) - 1; // Mês em JS é 0-indexado
      const year = parseInt(parts[2], 10);
      if (!isNaN(day) && !isNaN(month) && !isNaN(year)) {
        return new Date(year, month, day);
      }
    } else {
      // Tenta um parse direto (para ISO 8601 como YYYY-MM-DD)
      const directDate = new Date(dateString);
      if (!isNaN(directDate.getTime())) {
        return directDate;
      }
    }
  }
  return null; // Formato inválido
}


/**
* @summary Limpa e converte um valor de moeda (ex: "R$ 1.234,56") para um número float.
* @param {string|number} value O valor de entrada.
* @returns {number} O valor numérico.
*/
function parseCurrency(value) {
  if (typeof value === 'number') return value;
  if (!value || typeof value !== 'string') return 0;
  const cleaned = value
    .replace('R$', '')
    .replace(/\./g, '') // Remove separador de milhar
    .replace(',', '.')  // Troca vírgula decimal por ponto
    .trim();
  const number = parseFloat(cleaned);
  return isNaN(number) ? 0 : number;
}


/**
* @summary Limpa e converte um valor de porcentagem (ex: "1,50%") para um número float.
* @param {string|number} value O valor de entrada.
* @returns {number} O valor numérico (ex: 1.5).
*/
function parsePercent(value) {
  if (typeof value === 'number') return value;
  if (!value || typeof value !== 'string') return 0;
  const cleaned = value.replace('%', '').replace(',', '.').trim();
  const number = parseFloat(cleaned);
  return isNaN(number) ? 0 : number;
}



