/**
 * Normaliza entrada do usuário (DD/MM/AAAA | AAAA-MM-DD | Date) para ISO YYYY-MM-DD
 */
function isoFromUserInput_(input){
  if (!input) throw new Error('Data vazia.');
  if (Object.prototype.toString.call(input) === '[object Date]') return toISO_(input);

  const s = String(input).trim();

  // aceita direto ISO
  if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;

  // tenta BR (DD/MM/AAAA) e outros parseáveis
  const d = parseBrazilianDate(s);
  if (d && !isNaN(d.getTime())) return toISO_(d);

  throw new Error(`Data inválida: "${s}". Use DD/MM/AAAA ou AAAA-MM-DD.`);
}

/**
 * Processa todas as contas com try/catch por conta (não derruba tudo se 1 falhar).
 */
function processAllAccounts_(startISO, endISO, opts){
  bootstrap();
  const accounts = getAccounts_();
  if (accounts.length === 0) throw new Error('Nenhuma conta válida em PROPRIEDADES.');

  const errors = [];
  for (const acc of accounts){
    try{
      processAccount_(acc, startISO, endISO, opts || {force:true});
    }catch(err){
      const msg = `${acc.name}: ${err && err.message ? err.message : String(err)}`;
      errors.push(msg);
      Logger.log('ERRO %s', msg);
    }
  }
  return errors;
}

/**
 * Atualiza um intervalo (force=true) — útil para corrigir datas antigas.
 * Você pode chamar via código também: runRange('2025-12-23','2025-12-29')
 */
function runRange(startInput, endInput){
  const startISO = isoFromUserInput_(startInput);
  const endISO   = isoFromUserInput_(endInput);

  const s = (startISO <= endISO) ? startISO : endISO;
  const e = (startISO <= endISO) ? endISO : startISO;

  const errs = processAllAccounts_(s, e, {force:true});

  // Se rodar manualmente, avisa no UI
  try{
    if (errs.length){
      SpreadsheetApp.getUi().alert(
        `Atualização concluída (${s} → ${e}) com ${errs.length} erro(s).\n\n` +
        errs.slice(0, 20).join('\n') + (errs.length > 20 ? '\n...' : '')
      );
    }else{
      SpreadsheetApp.getUi().alert(`Atualização concluída (${s} → ${e}).`);
    }
  }catch(_){}
}

/** Prompt: 1 dia específico */
function runSingleDatePrompt(){
  const ui = SpreadsheetApp.getUi();
  const r = ui.prompt('Atualizar 1 dia', 'Digite a data (DD/MM/AAAA ou AAAA-MM-DD):', ui.ButtonSet.OK_CANCEL);
  if (r.getSelectedButton() !== ui.Button.OK) return;

  const iso = isoFromUserInput_(r.getResponseText());
  runRange(iso, iso);
}

/** Prompt: intervalo */
function runRangePrompt(){
  const ui = SpreadsheetApp.getUi();

  const r1 = ui.prompt('Atualizar intervalo', 'Data INICIAL (DD/MM/AAAA ou AAAA-MM-DD):', ui.ButtonSet.OK_CANCEL);
  if (r1.getSelectedButton() !== ui.Button.OK) return;

  const r2 = ui.prompt('Atualizar intervalo', 'Data FINAL (DD/MM/AAAA ou AAAA-MM-DD):', ui.ButtonSet.OK_CANCEL);
  if (r2.getSelectedButton() !== ui.Button.OK) return;

  runRange(r1.getResponseText(), r2.getResponseText());
}

/** Prompt: a partir de uma data até hoje */
function runFromDatePrompt(){
  const ui = SpreadsheetApp.getUi();
  const r = ui.prompt('Atualizar a partir de uma data', 'Data INICIAL (DD/MM/AAAA ou AAAA-MM-DD):', ui.ButtonSet.OK_CANCEL);
  if (r.getSelectedButton() !== ui.Button.OK) return;

  const startISO = isoFromUserInput_(r.getResponseText());
  const endISO   = toISO_(new Date());
  runRange(startISO, endISO);
}

/** Atalho pronto para o seu caso: 23/12 até hoje */
function runFixFrom_2025_12_23(){
  const endISO = toISO_(new Date());
  runRange('2025-12-23', endISO);
}

