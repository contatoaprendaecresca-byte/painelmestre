// === CONSTANTES E CONFIGURAÇÕES ===
const SHEET_NAMES = { MESTRE: 'MESTRE', PEDIDOS: 'PEDIDOS', RESUMO_MENSAL: 'RESUMO_MENSAL', PROPS: 'PROPRIEDADES' };
const TZ = 'America/Sao_Paulo';
const START_DATE = '2025-12-01'; // Ajuste conforme necessidade original
const BLOCK_DAYS = 10;
const SLEEP_MS = 350;
const SP = PropertiesService.getScriptProperties();

// Cabeçalho Padrão (Fallback)
const HEADER = [
  'Conta ID','Data','Dia Da Semana','Facebook (R$)','Cart','Checkout','Info. Pagamento','purshase','ROAS',
  'Google Ads (R$)','Total (R$)','Sessões GA4','Transações GA4','TX Conv Sessão','Receita Captada GA4 (R$)',
  'Ticket Médio (R$)','Receita Paga Bagy (R$)','Pedidos Pagos Bagy','Não Pagos Bagy (R$)','CPS (R$)',
  'CPA/Meta (R$)','ROAS/Diario [CAP]','Taxa De Rejeição GA4'
];
const HEADER_COLS = HEADER.length;

// Mapa de colunas (1-based)
const COL = {
  CONTA:1, DATA:2, DIA:3, FB:4, CART:5, CHECK:6, ADDPAY:7, PURCHASE:8, ROAS:9, GADS:10,
  TOTAL:11, SESS:12, TRANS:13, TXCONV:14, REVENUE:15, TICKET:16, BAGY_REV:17, BAGY_ORD:18,
  BAGY_NP:19, CPS:20, CPA:21, ROAS_CAP:22, BOUNCE:23
};

// === FUNÇÕES PRINCIPAIS DO MOTOR ===

function bootstrap(){
  const ss = SpreadsheetApp.getActive();
  // PROPRIEDADES
  let shP = ss.getSheetByName(SHEET_NAMES.PROPS);
  if(!shP){
    shP = ss.insertSheet(SHEET_NAMES.PROPS);
    shP.getRange(1,1,1,2).setValues([['Propriedade','Valor']]).setFontWeight('bold');
  }
  // MESTRE
  let sh = ss.getSheetByName(SHEET_NAMES.MESTRE);
  if(!sh){
    const tmpl = ss.getSheetByName('template') || ss.getSheetByName('Template') || ss.getSheetByName('TEMPLATE');
    if (tmpl){
      sh = tmpl.copyTo(ss);
      sh.setName(SHEET_NAMES.MESTRE);
      sh.setFrozenRows(1);
    } else {
      sh = ss.insertSheet(SHEET_NAMES.MESTRE);
      sh.getRange(1,1,1,HEADER_COLS).setValues([HEADER]).setFontWeight('bold');
      sh.setFrozenRows(1);
      applyHeaderFormats_(sh);
    }
  }
}

function applyHeaderFormats_(sh){
  sh.getRange('B2:B').setNumberFormat('dd/mm/yyyy');
  sh.getRange('D2:D').setNumberFormat('"R$" #,##0.00'); 
  sh.getRange('J2:J').setNumberFormat('"R$" #,##0.00'); 
  sh.getRange('L2:M').setNumberFormat('0');             
  sh.getRange('I2:I').setNumberFormat('0.00');          
  sh.getRange('X2:X').setNumberFormat('0.00%'); // Bounce
  for(let c=1;c<=HEADER_COLS;c++) sh.autoResizeColumn(c);
}

function syncPropsFromSheet(){
  const sh = SpreadsheetApp.getActive().getSheetByName(SHEET_NAMES.PROPS);
  if(!sh) throw new Error('Crie a aba PROPRIEDADES.');
  const last = sh.getLastRow();
  if(last<2) return;
  const data = sh.getRange(2,1,last-1,2).getValues();
  data.forEach(([k,v])=>{
    if(k) SP.setProperty(String(k).trim(), String(v||'').trim());
  });
  SpreadsheetApp.getUi().alert('Script Properties atualizadas.');
}

function getAccounts_(){
  const props = SP.getProperties();
  const groups = {};
  const re = /__(\d+)$/;
  for(const k in props){
    const m = k.match(re);
    const idx = m ? m[1] : '0';
    groups[idx] = groups[idx] || {name:`CONTA_${idx==='0'?'DEFAULT':idx}`};
    const o = groups[idx];
    if(k.startsWith('CONTA_NOME')) o.name = props[k];
    if(k.startsWith('GA4_PROPERTY_ID')) o.ga4 = props[k];
    if(k.startsWith('FB_AD_ACCOUNT_ID')) o.fbAct = props[k];
    if(k.startsWith('FB_ACCESS_TOKEN') || k.startsWith('FB_TOKEN')) o.fbTok = props[k];
  }
  return Object.values(groups).filter(o => (o.ga4 || (o.fbAct && o.fbTok)));
}

// === EXECUÇÃO ROTINEIRA ===

function runRecent3d(){
  bootstrap();
  const accounts = getAccounts_();
  if(accounts.length===0) throw new Error('Nenhuma conta válida em PROPRIEDADES.');
  const endISO = toISO_(new Date()); 
  const startISO = addDaysISO_(endISO, -2);
  for(const acc of accounts){
    processAccount_(acc, startISO, endISO, {force:true});
  }
}

function runRecent5d(){
  bootstrap();
  const accounts = getAccounts_();
  if(accounts.length===0) throw new Error('Nenhuma conta válida em PROPRIEDADES.');
  const endISO = toISO_(new Date()); 
