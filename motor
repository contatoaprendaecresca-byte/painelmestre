// Cache simples de JSON (ScriptCache). ttlSecs padrão 600 (10 min)
function cacheJSON_(key, supplierFn, ttlSecs){
  try{
    const cache = CacheService.getScriptCache();
    const hit = cache.get(key);
    if (hit) return JSON.parse(hit);
    const val = supplierFn() || {};
    cache.put(key, JSON.stringify(val), Math.max(30, Math.min(ttlSecs||600, 21600))); // até 6h
    return val;
  }catch(e){
    // fallback sem cache
    return supplierFn();
  }
}

// Lista todas as datas "YYYY-MM-DD" entre startISO e endISO (inclusive)
function enumerateDates_(startISO, endISO){
  const out = [];
  for (let d = startISO; d <= endISO; d = addDaysISO_(d, 1)){
    out.push(d);
  }
  return out;
}
