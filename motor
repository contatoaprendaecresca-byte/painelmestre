/* ============ POR CONTA (ordem nova + preserva fórmulas) ============ */
function processAccount_(acc, startISO, endISO, opts){
  const force = opts && opts.force === true;
  const ss = SpreadsheetApp.getActive();
  const sh = ss.getSheetByName(SHEET_MASTER);
  if(!sh) throw new Error(`Aba "${SHEET_MASTER}" não encontrada.`);

  // checkpoint por conta (usamos o NOME da conta)
  const key = `WORK__${acc.name}__LAST`;

  let cursorStart, cursorEnd;
  if(force){
    cursorStart = startISO;
    cursorEnd   = endISO;
  }else{
    const last = SP.getProperty(key);
    const start = (last && last >= startISO) ? addDaysISO_(last,1) : startISO;
    cursorStart = start;
    cursorEnd   = endISO;
  }
  if(cursorStart > cursorEnd) return;

  let cursor = cursorStart;
  let wroteLastISO = null;

  while (cursor <= cursorEnd){
    const blockStart = cursor;
    const blockEnd   = minISO_(addDaysISO_(blockStart, BLOCK_DAYS-1), cursorEnd);

    // coleta
    const meta = (acc.fbAct && acc.fbTok) ? fetchMetaDaily_(acc.fbAct, acc.fbTok, blockStart, blockEnd) : {};
    const ga4  = acc.ga4 ? fetchGA4Daily_(acc.ga4, blockStart, blockEnd) : {};

    // localizar linhas existentes para esse NOME de conta e range
    const {primaryRowByDate, duplicateRowsToClear} = findExistingRowsForRange_(sh, acc.name, blockStart, blockEnd);

    // limpa duplicados (apenas colunas sem fórmula; preserva fórmulas do template)
    if (duplicateRowsToClear.length){
      duplicateRowsToClear.forEach(r=>{
        clearNonFormulaCells_(sh, r);
      });
    }

    // payloads
    const toAppendPayload = [];   // [{vals}]
    const toUpdatePayload = [];   // [{row, vals}]

    for (let d = blockStart; d <= blockEnd; d = addDaysISO_(d,1)){
      const m = meta[d] || {spend:0, cart:0, checkout:0, addpay:0, purchase:0, roas:0};
      const g = ga4[d]  || {sessions:0, transactions:0, revenue:0, bounce:0};
      const gads = 0; // reservado

      const vals = {};
      vals[COL.CONTA]    = acc.name;                  // 1
      vals[COL.DATA]     = localDateFromISO_(d);      // 2
      vals[COL.DIA]      = weekdayPT_(d);             // 3
      vals[COL.FB]       = moneyToNumber_(m.spend);   // 4
      vals[COL.CART]     = toInt_(m.cart);            // 5
      vals[COL.CHECK]    = toInt_(m.checkout);        // 6
      vals[COL.ADDPAY]   = toInt_(m.addpay);          // 7
      vals[COL.PURCHASE] = toInt_(m.purchase);        // 8
      vals[COL.ROAS]     = toNumberSafe_(m.roas);     // 9
      vals[COL.GADS]     = moneyToNumber_(gads);      // 10
      // 11 Total (R$) é fórmula
      vals[COL.SESS]     = toInt_(g.sessions);        // 12
      vals[COL.TRANS]    = toInt_(g.transactions);    // 13
      // 14 fórmula
      vals[COL.REVENUE]  = moneyToNumber_(g.revenue); // 15 (escrevemos somente se célula NÃO tem fórmula)
      // 16 fórmula
      // 17–18 Bagy (opcional; manter manual)
      vals[COL.BOUNCE]   = normalizeBounce_(g.bounce);// 23

      const existingRow = primaryRowByDate[d] || null;
      if (existingRow){
        toUpdatePayload.push({row: existingRow, vals});
      }else{
        toAppendPayload.push({vals});
      }
      wroteLastISO = d;
    }

    // === APLICA ATUALIZAÇÕES ===
    toUpdatePayload.forEach(up=>{
      const r = up.row, v = up.vals;
      // 1..10
      sh.getRange(r, 1, 1, 10).setValues([[
        v[1],v[2],v[3],v[4],v[5],v[6],v[7],v[8],v[9],v[10]
      ]]);
      // 12..13
      sh.getRange(r, 12, 1, 2).setValues([[ v[12], v[13] ]]);
      // 15 Receita GA4 (só se não houver fórmula na célula)
      setIfNoFormula_(sh, r, 15, v[15]);
      // 23
      sh.getRange(r, 23).setValue(v[23]);
    });

    // === APLICA INSERTS (aloca linhas vazias dentro do template) ===
    if (toAppendPayload.length){
      const rows = allocateEmptyRows_(sh, toAppendPayload.length);
      toAppendPayload.forEach((ap, idx)=>{
        const r = rows[idx], v = ap.vals;
        // 1..10
        sh.getRange(r, 1, 1, 10).setValues([[
          v[1],v[2],v[3],v[4],v[5],v[6],v[7],v[8],v[9],v[10]
        ]]);
        // 12..13
        sh.getRange(r, 12, 1, 2).setValues([[ v[12], v[13] ]]);
        // 15 Receita GA4 (só se não houver fórmula na célula)
        setIfNoFormula_(sh, r, 15, v[15]);
        // 23
        sh.getRange(r, 23).setValue(v[23]);
      });
    }

    Utilities.sleep(SLEEP_MS);
    cursor = addDaysISO_(blockEnd,1);
  }

  if (!force && wroteLastISO){
    SP.setProperty(key, wroteLastISO);
  }
}

/* ============ COLETA META (com paginação e parser de R$) ============ */
function fetchMetaDaily_(actId, token, startISO, endISO){
  const map = {};
  const base = 'https://graph.facebook.com/v19.0/' + encodeURIComponent(actId) + '/insights';
  const timeRange = JSON.stringify({ since:startISO, until:endISO });

  let url = `${base}?fields=spend,actions,action_values` +
            `&level=account&time_increment=1` +
            `&time_range=${encodeURIComponent(timeRange)}` +
            `&access_token=${encodeURIComponent(token)}`;

  while (url){
    const res = UrlFetchApp.fetch(url, { method:'get', muteHttpExceptions:true });
    if (res.getResponseCode() < 200 || res.getResponseCode() >= 300){
      Logger.log('Meta error %s: %s', res.getResponseCode(), res.getContentText());
      break;
    }
    const json = JSON.parse(res.getContentText());
    (json.data || []).forEach(row=>{
      const ds     = row.date_start; // YYYY-MM-DD
      const spend  = moneyToNumber_(row.spend);

      let cart=0, checkout=0, addpay=0, purchase=0, purchaseValue=0;

      (row.actions||[]).forEach(a=>{
        const t = a.action_type;
        const v = toInt_(a.value);
        if (t==='add_to_cart') cart += v;
        else if (t==='initiate_checkout' || t==='checkout_initiated') checkout += v;
        else if (t==='add_payment_info') addpay += v;
        else if (t==='purchase') purchase += v;
      });

      (row.action_values||[]).forEach(av=>{
        if (av.action_type==='purchase') purchaseValue += moneyToNumber_(av.value);
      });

      const roas = spend > 0 ? (purchaseValue / spend) : 0;
      map[ds] = {spend, cart, checkout, addpay, purchase, roas};
    });

    url = (json.paging && json.paging.next) ? json.paging.next : null;
  }
  return map;
}

/* ============ COLETA GA4 (parser de dinheiro p/ receita) ============ */
function fetchGA4Daily_(propertyId, startISO, endISO){
  if (typeof AnalyticsData === 'undefined' || !AnalyticsData.Properties || !AnalyticsData.Properties.runReport){
    throw new Error('GA4 desativado: ative "Google Analytics Data API" em Serviços Avançados e no Console Cloud.');
  }

  const req = {
    dateRanges: [{ startDate:startISO, endDate:endISO }],
    dimensions: [{ name:'date' }],
    metrics: [
      { name:'sessions' },
      { name:'transactions' },
      { name:'purchaseRevenue' },
      { name:'bounceRate' }
    ]
  };

  const resp = AnalyticsData.Properties.runReport(req, 'properties/' + propertyId);
  const map = {};
  (resp.rows || []).forEach(r=>{
    const d  = r.dimensionValues[0].value; // YYYYMMDD
    const ds = `${d.slice(0,4)}-${d.slice(4,6)}-${d.slice(6,8)}`;
    const sessions     = toInt_(r.metricValues[0].value);
    const transactions = toInt_(r.metricValues[1].value);
    const revenue      = moneyToNumber_(r.metricValues[2].value);
    let   bounce       = toNumberSafe_(r.metricValues[3].value);
    map[ds] = { sessions, transactions, revenue, bounce };
  });
  return map;
}

/* ============ LOCALIZAÇÃO DE LINHAS (nome conta + data) ============ */
function findExistingRowsForRange_(sh, accountName, startISO, endISO){
  const last = sh.getLastRow();
  const result = { primaryRowByDate: {}, duplicateRowsToClear: [] };
  if (last < 2) return result;

  // Só precisamos de A (conta) e B (data)
  const rng = sh.getRange(2, 1, last-1, 2).getValues();
  for (let i = 0; i < rng.length; i++){
    const rowIndex = i + 2;
    const accCell = String(rng[i][0] || '').trim(); // Coluna A
    const cellB   = rng[i][1];
    const dISO    = (cellB instanceof Date) ? toISO_(cellB) : String(cellB || '');

    if (accCell === String(accountName).trim() && dISO >= startISO && dISO <= endISO){
      if (!result.primaryRowByDate[dISO]){
        result.primaryRowByDate[dISO] = rowIndex;
      } else {
        result.duplicateRowsToClear.push(rowIndex);
      }
    }
  }
  return result;
}

/* ============ ALOCAÇÃO DE LINHAS NO TEMPLATE ============ */
function allocateEmptyRows_(sh, needCount){
  const maxRows = sh.getMaxRows();
  if (maxRows < 2) throw new Error('Template sem linhas úteis.');
  // Coluna B (Data) da linha 2 até o final (displayValues p/ detectar vazios visuais)
  const rng = sh.getRange(2, COL.DATA, maxRows-1, 1).getDisplayValues();
  const rows = [];
  for (let i=0; i<rng.length && rows.length<needCount; i++){
    const v = String(rng[i][0]||'').trim();
    if (v === '') rows.push(i+2); // linha (1-based)
  }
  if (rows.length < needCount){
    throw new Error('Template não tem linhas vazias suficientes para preencher os dados.');
  }
  return rows;
}

/* ============ LIMPEZA SÓ EM COLUNAS SEM FÓRMULA ============ */
function clearNonFormulaCells_(sh, row){
  // Blocos sem fórmula: 1..10, 12..13, 15 (se sem fórmula), 17..18, 23
  sh.getRange(row, 1, 1, 10).clearContent();      // 1..10
  sh.getRange(row, 12, 1, 2).clearContent();      // 12..13
  sh.getRange(row, 17, 1, 2).clearContent();      // 17..18
  sh.getRange(row, 23, 1, 1).clearContent();      // 23
}

/* ======== HELPER: set se a célula não tiver fórmula ======== */
function setIfNoFormula_(sh, row, col, value){
  const cell = sh.getRange(row, col);
  if (!cell.getFormula()) cell.setValue(value);
}

/* ============ HELPERS ============ */
function localDateFromISO_(iso){ // "YYYY-MM-DD" -> Date local 12:00
  const p = iso.split('-');
  return new Date(Number(p[0]), Number(p[1])-1, Number(p[2]), 12, 0, 0);
}

function toISO_(d){ // aceita Date ou "YYYY-MM-DD"
  const tz = Session.getScriptTimeZone() || TZ;
  if (typeof d === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(d)) return d;
  return Utilities.formatDate(new Date(d), tz, 'yyyy-MM-dd');
}

function addDaysISO_(iso, n){ // opera sempre em horário local
  const p  = iso.split('-');
  const dt = new Date(Number(p[0]), Number(p[1])-1, Number(p[2]), 12, 0, 0);
  dt.setDate(dt.getDate()+n);
  return toISO_(dt);
}

function minISO_(a,b){ return a<b ? a : b; }

function weekdayPT_(iso){
  const d = localDateFromISO_(iso);
  const dias = ['Domingo','Segunda-feira','Terça-feira','Quarta-feira','Quinta-feira','Sexta-feira','Sábado'];
  return dias[d.getDay()];
}

/* ===== PARSER ROBUSTO DE DINHEIRO ===== */
function moneyToNumber_(v){
  if (v == null || v === '') return 0;
  if (typeof v === 'number') return v;
  let s = String(v).replace(/\u00A0/g, ' ').trim();
  s = s.replace(/R\$\s?/gi, '').trim();
  const negative = /^\(.*\)$/.test(s);
  if (negative) s = s.replace(/[()]/g, '');
  if (/^\d{1,3}(\.\d{3})*,\d{2}$/.test(s)) {
    s = s.replace(/\./g, '').replace(',', '.');
  } else if (/^\d{1,3}(,\d{3})*\.\d{2}$/.test(s)) {
    s = s.replace(/,/g, '');
  } else {
    if (s.indexOf(',') >= 0 && s.indexOf('.') === -1) {
      s = s.replace(/\./g, '').replace(',', '.');
    } else {
      s = s.replace(/(?<=\d)[,](?=\d{3}\b)/g, '');
    }
  }
  let n = Number(s);
  if (isNaN(n)) return 0;
  if (negative) n = -Math.abs(n);
  return n;
}

function toInt_(v){
  const n = Number(v);
  return isFinite(n) ? Math.round(n) : 0;
}

function toNumberSafe_(v){
  const n = Number(v);
  return isFinite(n) ? n : 0;
}

function normalizeBounce_(v){
  let x = toNumberSafe_(v);
  if (x > 1) x = x / 100;
  if (x < 0) x = 0;
  if (x > 1) x = 1;
  return x;
}

// Lista triggers deste projeto em uma janela (handler | source | type)
function menuListTriggers(){
  const triggers = ScriptApp.getProjectTriggers();
  const lines = triggers.map(t => {
    let src = t.getTriggerSource && t.getTriggerSource();
    let et  = t.getEventType && t.getEventType();
    return `• ${t.getHandlerFunction()} | ${src || 'CLOCK'} | ${et || 'TIME'}`;
  });
  const msg = lines.length ? lines.join('\n') : 'Nenhum trigger ativo.';
  SpreadsheetApp.getUi().alert('Triggers deste projeto:\n\n' + msg);
}

// Remove o trigger que chama runRecent3d (caso exista)
function uninstallRecent3dTrigger(){
  const fn = 'runRecent3d';
  const toDelete = ScriptApp.getProjectTriggers().filter(t => t.getHandlerFunction() === fn);
  toDelete.forEach(t => ScriptApp.deleteTrigger(t));
  SpreadsheetApp.getUi().alert(`Removidos ${toDelete.length} trigger(s) do handler "${fn}".`);
}

