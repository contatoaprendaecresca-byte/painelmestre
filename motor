/* ============== ESTRUTURA ============== */
function bootstrap(){
  const ss = SpreadsheetApp.getActive();

  // PROPRIEDADES
  let shP = ss.getSheetByName(SHEET_PROPS);
  if(!shP){
    shP = ss.insertSheet(SHEET_PROPS);
    shP.getRange(1,1,1,2).setValues([['Propriedade','Valor']]).setFontWeight('bold');
  }

  // MESTRE a partir do template (mantém fórmulas/formatos)
  let sh = ss.getSheetByName(SHEET_MASTER);
  if(!sh){
    const tmpl = ss.getSheetByName('template') || ss.getSheetByName('Template') || ss.getSheetByName('TEMPLATE');
    if (tmpl){
      sh = tmpl.copyTo(ss);
      sh.setName(SHEET_MASTER);
      sh.setFrozenRows(1);
    }else{
      // Fallback: cria do zero com HEADER (caso não exista template)
      sh = ss.insertSheet(SHEET_MASTER);
      sh.getRange(1,1,1,HEADER_COLS).setValues([HEADER]).setFontWeight('bold');
      sh.setFrozenRows(1);
      applyHeaderFormats_(sh);
    }
  }
}

function applyHeaderFormats_(sh){
  // Fallback (apenas quando não há template). Template já traz formatação.
  sh.getRange('B2:B').setNumberFormat('dd/mm/yyyy');
  sh.getRange('D2:D').setNumberFormat('"R$" #,##0.00'); // Facebook
  sh.getRange('J2:J').setNumberFormat('"R$" #,##0.00'); // Google Ads
  // Total (K/11) é fórmula no template; no fallback, não definimos fórmula aqui.
  sh.getRange('L2:M').setNumberFormat('0');             // Sessões/Transações GA4
  sh.getRange('I2:I').setNumberFormat('0.00');          // ROAS
  sh.getRange('X2:X').setNumberFormat('0.00%');         // Bounce (23)
  for(let c=1;c<=HEADER_COLS;c++) sh.autoResizeColumn(c);
}

/* ============== PROPRIEDADES ============== */
function syncPropsFromSheet(){
  const sh = SpreadsheetApp.getActive().getSheetByName(SHEET_PROPS);
  if(!sh) throw new Error('Crie a aba PROPRIEDADES.');
  const last = sh.getLastRow();
  if(last<2) return;
  const data = sh.getRange(2,1,last-1,2).getValues();
  data.forEach(([k,v])=>{
    if(k) SP.setProperty(String(k).trim(), String(v||'').trim());
  });
  SpreadsheetApp.getUi().alert('Script Properties atualizadas.');
}

/* 
  PROPRIEDADES esperadas (exemplos):
  CONTA_NOME__1       = Minha Conta 1 (display/coluna A)
  FB_AD_ACCOUNT_ID__1 = act_123456789012345
  FB_ACCESS_TOKEN__1  = EAAG...
  GA4_PROPERTY_ID__1  = 123456789
  (sufixo __X permite múltiplas contas; sem sufixo = default)
*/
function getAccounts_(){
  const props = SP.getProperties();
  const groups = {};
  const re = /__(\d+)$/;
  for(const k in props){
    const m = k.match(re);
    const idx = m ? m[1] : '0';
    groups[idx] = groups[idx] || {name:`CONTA_${idx==='0'?'DEFAULT':idx}`};
    const o = groups[idx];
    if(k.startsWith('CONTA_NOME')) o.name = props[k];
    if(k.startsWith('GA4_PROPERTY_ID')) o.ga4 = props[k];
    if(k.startsWith('FB_AD_ACCOUNT_ID')) o.fbAct = props[k];
    if(k.startsWith('FB_ACCESS_TOKEN') || k.startsWith('FB_TOKEN')) o.fbTok = props[k];
  }
  // só retorna contas com GA4 e/ou Meta válidos
  return Object.values(groups).filter(o => (o.ga4 || (o.fbAct && o.fbTok)));
}

/* ============== EXECUÇÃO ============== */
function runBlocks(){
  bootstrap();
  const accounts = getAccounts_();
  if(accounts.length===0) throw new Error('Nenhuma conta válida em PROPRIEDADES.');
  const todayISO = toISO_(new Date());
  for(const acc of accounts){
    processAccount_(acc, START_DATE, todayISO);
  }
}

function resetProgress(){
  const all = SP.getProperties();
  Object.keys(all).forEach(k=>{
    if(k.startsWith('WORK__')) SP.deleteProperty(k);
  });
}

