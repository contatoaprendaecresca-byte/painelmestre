/* ===== Config (defaults) ===== */
const BAGY_MTD_REF_DEFAULT   = '';          // '' = automático
const BAGY_START_DATE_DEFAULT = '';         // '' = usa primeira data com dados

function _bagyProp_(key){
  try{
    return (PropertiesService.getScriptProperties().getProperty(key) || '').trim();
  }catch(e){
    return '';
  }
}

/* Retorna a última data existente em rows (coluna r.data) */
function lastDataDate_(rows){
  let best = null;
  rows.forEach(r=>{
    const d = parseDate_(r.data);
    if (d && (!best || d > best)) best = d;
  });
  return best;
}

/* Encontra a última data com dados dentro de um mês/ano específico */
function lastDataInMonth_(rows, year, month){ // month: 0..11
  let best = null;
  rows.forEach(r=>{
    const d = parseDate_(r.data);
    if (d && d.getFullYear() === year && d.getMonth() === month){
      if (!best || d > best) best = d;
    }
  });
  return best;
}

/* Constrói a data de referência para o MTD (override, última com dados, ou hoje) */
function resolveMTDRefDate_(rows, tz){
  const override = (_bagyProp_('BAGY_MTD_REF') || BAGY_MTD_REF_DEFAULT).trim();
  const today = new Date();

  if (override){
    const s = override;

    // YYYY-MM-DD
    if (/^\d{4}-\d{2}-\d{2}$/.test(s)){
      const y = +s.slice(0,4), m = +s.slice(5,7)-1, d = +s.slice(8,10);
      return new Date(y, m, d);
    }

    // YYYY-MM
    if (/^\d{4}-\d{2}$/.test(s)){
      const y = +s.slice(0,4), m = +s.slice(5,7)-1;
      const lastInMonth = lastDataInMonth_(rows, y, m);
      if (lastInMonth) return lastInMonth;
      // fallback: último dia do mês
      return new Date(y, m+1, 0);
    }
  }

  // automático: usa última data com dados (se houver), senão hoje
  const last = lastDataDate_(rows);
  return last || today;
}

function daysInMonth_(d){
  return new Date(d.getFullYear(), d.getMonth()+1, 0).getDate();
}

/* ====== MTD vs M-1 MTD (apenas Bagy) ====== */
function runBagyMTDOverview_(){
  const metrics = buildBagyMTDOverview_();
  writeBagyMTDOverviewSheet_(metrics);
  SpreadsheetApp.getUi().alert('BAGY MTD gerado/atualizado com sucesso.');
}

function buildBagyMTDOverview_(){
  const tz = (typeof AC_TZ!=='undefined' ? AC_TZ : Session.getScriptTimeZone() || 'America/Sao_Paulo');
  const {rows, nome} = loadMestre_BAGY_();

  const ref    = resolveMTDRefDate_(rows, tz);
  const refDay = new Date(ref.getFullYear(), ref.getMonth(), ref.getDate());

  const startCurr = new Date(refDay.getFullYear(), refDay.getMonth(), 1);
  const endCurr   = refDay;

  const prevMonth = new Date(refDay.getFullYear(), refDay.getMonth()-1, 1);
  const endPrev   = new Date(
    prevMonth.getFullYear(),
    prevMonth.getMonth(),
    Math.min(refDay.getDate(), daysInMonth_(prevMonth))
  );
  const startPrev = new Date(prevMonth.getFullYear(), prevMonth.getMonth(), 1);

  const name = (typeof CLIENT_NAME!=='undefined' && CLIENT_NAME
    ? CLIENT_NAME
    : (nome || SpreadsheetApp.getActive().getName())
  ).toString();

  const invA  = sumWindowBR_(rows, "inv",  startCurr, endCurr);
  const invP  = sumWindowBR_(rows, "inv",  startPrev, endPrev);

  const recA  = sumWindowBR_(rows, "paga", startCurr, endCurr);
  const recP  = sumWindowBR_(rows, "paga", startPrev, endPrev);

  const pedA  = sumWindowBR_(rows, "ped",  startCurr, endCurr);
  const pedP  = sumWindowBR_(rows, "ped",  startPrev, endPrev);

  const npvA  = sumWindowBR_(rows, "npv",  startCurr, endCurr);
  const npvP  = sumWindowBR_(rows, "npv",  startPrev, endPrev);

  const totValA = recA + npvA;
  const totValP = recP + npvP;

  const aprA = ratioSafe_(recA, totValA);
  const aprP = ratioSafe_(recP, totValP);

  const roasA = ratioSafe_(recA, invA);
  const roasP = ratioSafe_(recP, invP);

  const cpaA  = ratioSafe_(invA, pedA);
  const cpaP  = ratioSafe_(invP, pedP);

  const tktA  = ratioSafe_(recA, pedA);
  const tktP  = ratioSafe_(recP, pedP);

  const vInv = varPct_(invA, invP);
  const vTot = varPct_(totValA, totValP);
  const vPed = varPct_(pedA, pedP);
  const vRec = varPct_(recA, recP);
  const vNpv = varPct_(npvA, npvP);

  // mensagem simples
  let msg = '';
  if (vTot > 0.05 && vRec > 0.05) msg = 'Boa! Crescimento de receita e volume.';
  else if (vTot < -0.05) msg = 'Atenção: queda no total (pagos + não pagos).';
  else msg = 'Estável: pequenas variações no MTD.';

  return {
    nome: name,
    periodo: { startCurr, endCurr, startPrev, endPrev },
    investimento: { atual: invA, prev: invP, var: vInv },
    pedidosAprov: { atual: pedA, prev: pedP, var: vPed },
    receitaAprov: { atual: recA, prev: recP, var: vRec },
    receitaTotal: { atual: totValA, prev: totValP, var: vTot },
    expiradosVal: { atual: npvA, prev: npvP, var: vNpv },
    aprovacaoVal: { atual: aprA, prev: aprP },
    roas: { atual: roasA, prev: roasP },
    cpa: { atual: cpaA, prev: cpaP },
    ticket: { atual: tktA, prev: tktP },
    mensagem: msg
  };
}

function writeBagyMTDOverviewSheet_(metrics){
  const ss = SpreadsheetApp.getActive();
  const shName = 'BAGY_MTD';
  const sh = ss.getSheetByName(shName) || ss.insertSheet(shName);

  // limpa só área usada
  sh.clear({contentsOnly:true});

  const name = metrics.nome || ss.getName();
  const {startCurr, endCurr, startPrev, endPrev} = metrics.periodo;

  sh.getRange(1,1,1,12).setValues([[
    "Conta",
    "Período",
    "Investimento (A/P)",
    "Pedidos Pagos (A/P)",
    "Receita Paga (A/P)",
    "Receita Total (A/P)",
    "Não Pagos (A/P)",
    "Aprovação % (A/P)",
    "ROAS (A/P)",
    "CPA (A/P)",
    "Ticket (A/P)",
    "Mensagem"
  ]]).setFontWeight("bold");

  const periodoStr =
    fmtDDMM_(startCurr) + '–' + fmtDDMM_(endCurr) +
    ' (vs. ' + fmtDDMM_(startPrev) + '–' + fmtDDMM_(endPrev) + ')';

  const row = [[
    name, periodoStr,
    money_(metrics.investimento.atual) + ' / ' + money_(metrics.investimento.prev),
    int_(metrics.pedidosAprov.atual) + ' / ' + int_(metrics.pedidosAprov.prev),
    money_(metrics.receitaAprov.atual) + ' / ' + money_(metrics.receitaAprov.prev),
    money_(metrics.receitaTotal.atual) + ' / ' + money_(metrics.receitaTotal.prev),
    money_(metrics.expiradosVal.atual) + ' / ' + money_(metrics.expiradosVal.prev),
    pct_(metrics.aprovacaoVal.atual) + ' / ' + pct_(metrics.aprovacaoVal.prev),
    metrics.roas.atual.toFixed(2) + 'x / ' + metrics.roas.prev.toFixed(2) + 'x',
    money_(metrics.cpa.atual) + ' / ' + money_(metrics.cpa.prev),
    money_(metrics.ticket.atual) + ' / ' + money_(metrics.ticket.prev),
    metrics.mensagem
  ]];

  sh.getRange(2,1,1,row[0].length).setValues(row);
  sh.autoResizeColumns(1,12);
}

/* ====== RESUMO_BAGY_MENSAL (colunas lado a lado para Looker) ====== */
function buildBagyMonthlyRollup_(){
  const tz = (typeof AC_TZ!=='undefined'
              ? AC_TZ
              : Session.getScriptTimeZone() || 'America/Sao_Paulo');

  const {rows: dataRows, nome} = loadMestre_BAGY_();
  const name = (typeof CLIENT_NAME!=='undefined' && CLIENT_NAME
    ? CLIENT_NAME
    : (nome || SpreadsheetApp.getActive().getName())
  ).toString();

  // Início do mensal: BAGY_START_DATE (Script Properties) > default > primeira data com dados
  const startISO = (_bagyProp_('BAGY_START_DATE') || BAGY_START_DATE_DEFAULT).trim();
  let start = null;

  if (startISO && /^\d{4}-\d{2}-\d{2}$/.test(startISO)){
    start = new Date(+startISO.slice(0,4), +startISO.slice(5,7)-1, 1);
  }else{
    start = firstDataDate_(dataRows) || new Date(new Date().getFullYear(), new Date().getMonth(), 1);
    start = new Date(start.getFullYear(), start.getMonth(), 1);
  }

  const today = new Date();
  const end = new Date(today.getFullYear(), today.getMonth(), 1); // mês atual (começo)

  const months = [];
  for (let d = new Date(start.getFullYear(), start.getMonth(), 1); d <= end; d = new Date(d.getFullYear(), d.getMonth()+1, 1)){
    months.push(new Date(d.getFullYear(), d.getMonth(), 1));
  }

  const out = [];
  months.forEach(m0=>{
    const m1 = new Date(m0.getFullYear(), m0.getMonth()+1, 0);
    const inv  = sumWindowBR_(dataRows, "inv",  m0, m1);
    const paga = sumWindowBR_(dataRows, "paga", m0, m1);
    const ped  = sumWindowBR_(dataRows, "ped",  m0, m1);
    const npv  = sumWindowBR_(dataRows, "npv",  m0, m1);

    const totalVal = paga + npv;
    const aprovPct = ratioSafe_(paga, totalVal);
    const roas = ratioSafe_(paga, inv);
    const cpa  = ratioSafe_(inv, ped);
    const tkt  = ratioSafe_(paga, ped);

    out.push({
      conta: name,
      mes: Utilities.formatDate(m0, tz, "yyyy-MM"),
      investimento: inv,
      receita_paga: paga,
      pedidos_pagos: ped,
      nao_pagos: npv,
      receita_total: totalVal,
      aprovacao_pct: aprovPct,
      roas: roas,
      cpa: cpa,
      ticket: tkt
    });
  });

  writeBagyMonthlyRollupSheet_(out);
  SpreadsheetApp.getUi().alert('RESUMO_BAGY_MENSAL gerado/atualizado com sucesso.');
}

