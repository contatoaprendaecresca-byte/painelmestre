/* ===================== Leitura da MESTRE (Bagy view) =====================
   Depende dos helpers: norm_, findCol_, toNumber_, parseDate_
   (abaixo estão os helpers usados pelo bagy.gs) */
function loadMestre_BAGY_(){
  const ss = SpreadsheetApp.getActive();
  const sh = ss.getSheetByName("MESTRE");
  if (!sh) throw new Error('Aba "MESTRE" não encontrada.');

  const vals = sh.getDataRange().getDisplayValues();
  if (vals.length < 2) return {rows: [], nome: ss.getName()};

  const H = vals[0].map(norm_);

  const iData   = findCol_(H, ["data","date"]);
  const iInv    = findCol_(H, ["total (r$)","investimento","gasto total (r$)","ads total (r$)"]);
  const iFb     = findCol_(H, ["facebook (r$)","meta (r$)","meta ads (r$)","facebook ads (r$)"]);
  const iPaga   = findCol_(H, ["receita paga bagy (r$)","receita pedidos pagos (r$)","faturamento (r$)","faturamento loja (r$)"]);
  const iPed    = findCol_(H, ["pedidos pagos bagy","pedidos pagos","pedidos"]);
  const iNaoPag = findCol_(H, ["não pagos bagy (r$)","nao pagos bagy (r$)","expirados (r$)","nao pagos (r$)"]);
  const iNome   = findCol_(H, ["conta id","conta","nome da conta","account name","propriedade/valor"]);

  if (iData === -1) throw new Error('Coluna "Data" não encontrada na MESTRE.');

  const rows = vals.slice(1).map(r=>{
    return {
      data: r[iData],
      inv:  (iInv!==-1 ? r[iInv] : (iFb!==-1 ? r[iFb] : 0)),
      paga: (iPaga!==-1 ? r[iPaga] : 0),
      ped:  (iPed!==-1 ? r[iPed] : 0),
      npv:  (iNaoPag!==-1 ? r[iNaoPag] : 0),
      nome: (iNome!==-1 ? r[iNome] : "")
    };
  });

  const nome = (rows.find(r=>String(r.nome||"").trim())?.nome || ss.getName()).trim();
  return {rows, nome};
}

/* ===== Helpers Bagy ===== */
function norm_(s){
  return String(s||"")
    .trim()
    .toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g,'');
}

function findCol_(Hnorm, candidates){
  for (const c of candidates){
    const idx = Hnorm.indexOf(norm_(c));
    if (idx !== -1) return idx;
  }
  return -1;
}

// aceita "R$ 1.234,56", "1234.56", "(1.234,56)"
function toNumber_(v){
  if (typeof v === 'number') return isFinite(v) ? v : 0;
  let s = String(v||'').trim();
  if (!s) return 0;
  let negative = /^\(.*\)$/.test(s);
  if (negative) s = s.replace(/[()]/g, '');
  s = s.replace(/\s/g,'').replace('R$','').replace('r$','');

  if (/^\d{1,3}(\.\d{3})*,\d{2}$/.test(s)) {
    s = s.replace(/\./g, '').replace(',', '.');
  } else if (/^\d{1,3}(,\d{3})*\.\d{2}$/.test(s)) {
    s = s.replace(/,/g, '');
  } else {
    if (s.indexOf(',') >= 0 && s.indexOf('.') === -1) {
      s = s.replace(/\./g, '').replace(',', '.');
    } else {
      s = s.replace(/(?<=\d)[,](?=\d{3}\b)/g, '');
    }
  }

  let n = Number(s);
  if (isNaN(n)) return 0;
  if (negative) n = -Math.abs(n);
  return n;
}

function parseDate_(v){
  if (!v) return null;
  if (Object.prototype.toString.call(v) === '[object Date]') return v;

  const s = String(v).trim();

  // dd/mm/yyyy
  const m1 = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})/);
  if (m1){
    const d = +m1[1], m = +m1[2]-1, y = +m1[3];
    const dt = new Date(y,m,d);
    return isNaN(dt.getTime()) ? null : dt;
  }

  // yyyy-mm-dd
  const m2 = s.match(/^(\d{4})-(\d{2})-(\d{2})/);
  if (m2){
    const y = +m2[1], m = +m2[2]-1, d = +m2[3];
    const dt = new Date(y,m,d);
    return isNaN(dt.getTime()) ? null : dt;
  }

  const dt = new Date(s);
  return isNaN(dt.getTime()) ? null : dt;
}

function sumWindowBR_(rows, key, start, end){
  let sum = 0;
  rows.forEach(r=>{
    const d = parseDate_(r.data);
    if (!d) return;
    if (d >= start && d <= end){
      sum += toNumber_(r[key]);
    }
  });
  return sum;
}

function firstDataDate_(rows){
  let best = null;
  rows.forEach(r=>{
    const d = parseDate_(r.data);
    if (d && (!best || d < best)) best = d;
  });
  return best;
}

function ratioSafe_(a,b){
  a = toNumber_(a); b = toNumber_(b);
  return b ? (a/b) : 0;
}

function varPct_(a,b){
  a = toNumber_(a); b = toNumber_(b);
  if (!b) return a ? 1 : 0;
  return (a-b)/Math.abs(b);
}

function money_(n){
  n = toNumber_(n);
  return n.toLocaleString('pt-BR', {style:'currency', currency:'BRL'});
}

function int_(n){
  n = toNumber_(n);
  return Math.round(n).toLocaleString('pt-BR');
}

function pct_(n){
  n = toNumber_(n);
  return (n*100).toFixed(2).replace('.',',') + '%';
}

function fmtDDMM_(d){
  const dd = String(d.getDate()).padStart(2,'0');
  const mm = String(d.getMonth()+1).padStart(2,'0');
  return `${dd}/${mm}`;
}
