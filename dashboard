<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <!-- Força mobile (evita “desktop mode” no iPhone/Safari) -->
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1" />
  <title>Pop Modas Jeans</title>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

  <style>
    :root{
      /* ===== C6-like: dark + laranja (SEM gradientes) ===== */
      --page:   #07070a;
      --page2:  #0b0b10;
      --card:   #101018;
      --stroke: rgba(255,255,255,.10);
      --text:   #ffffff;
      --muted:  rgba(255,255,255,.66);

      --shadow:  0 18px 40px rgba(0,0,0,.42);
      --shadow2: 0 10px 22px rgba(0,0,0,.36);

      --r: 14px;
      --accent:  #ff7a00;
      --good:    #22c55e;
      --bad:     #ef4444;
      --neu:     rgba(255,255,255,.80);

      /* ===== Mobile tokens ===== */
      --pad: 8px;
      --gap: 8px;
      --tap: 40px;
      --fs1: 20px;
      --fs2: 12px;
      --fs3: 11px;

      /* largura tipo “app” (ajuste se quiser) */
      --maxw: 680px;
    }

    *{ box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      margin:0;
      font-family: ui-sans-serif, -apple-system, system-ui, Segoe UI, Roboto, Arial;
      color: var(--text);
      color-scheme: dark;
      background: var(--page);
    }

    /* Container (app-like) */
    .wrap{
      max-width: var(--maxw);
      margin: 0 auto;
      padding: 8px var(--pad) 14px;
    }

    /* Topbar */
    ..topbar{
  position: relative;   /* ou static */
  top: auto;
  z-index: auto;

  display:flex;
  flex-direction: column;
  gap: 10px;
  padding: 10px;
  border-radius: var(--r);
  border: 1px solid var(--stroke);
  background: rgba(16,16,24,.82);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: var(--shadow);
  overflow:hidden;
}


    .title{ display:flex; flex-direction:column; gap:6px; }
    .title h1{ margin:0; font-size: 16px; letter-spacing:-.2px; }
    .title p{ margin:0; color: var(--muted); font-size: 12px; }

    .controls{ display:flex; flex-direction: column; gap: 10px; }

    .field{ display:flex; flex-direction:column; gap:6px; width: 100%; }
    .field label{ font-size: 11px; color: var(--muted); }

    input[type="date"]{
      height: var(--tap);
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: 0 12px;
      background: rgba(255,255,255,.06);
      color: var(--text);
      outline:none;
    }

    /* Chips (scroll horizontal) */
    .row{
      display:flex;
      gap: 10px;
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 2px;
    }
    .row::-webkit-scrollbar{ display:none; }

    .btn{
      height: var(--tap);
      padding: 0 12px;
      border-radius: 14px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.06);
      color: var(--text);
      cursor:pointer;
      user-select:none;
      font-size: 12px;
      white-space:nowrap;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width: 124px;
      transition: transform .06s ease, filter .15s ease;
    }
    .btn:active{ transform: translateY(1px); }

    .btn-primary{
      border: 0;
      background: var(--accent);
      color: #0b0b10;
      font-weight: 900;
      width: 100%;
      min-width: 0;
      box-shadow: 0 16px 34px rgba(255,122,0,.18);
    }

    .switch{
      display:flex;
      align-items:center;
      gap:10px;
      padding: 10px 12px;
      border: 1px solid var(--stroke);
      border-radius: 14px;
      background: rgba(255,255,255,.06);
      min-height: var(--tap);
      font-size: 12px;
      color: var(--muted);
    }

    .err{
      margin-top: 10px;
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid rgba(239,68,68,.30);
      background: rgba(239,68,68,.10);
      color: rgba(255,255,255,.92);
      display:none;
    }

    /* KPIs: 1 por linha */
    .grid{
      display:grid;
      grid-template-columns: 1fr;
      gap: var(--gap);
      margin-top: 14px;
    }

    .kpi, .panel{
      background: var(--card);
      border: 1px solid var(--stroke);
      border-radius: var(--r);
      box-shadow: var(--shadow2);
      overflow:hidden;
    }

    .kpi{ padding: 12px; }
    .kpi .label{ font-size: var(--fs2); color: var(--muted); }
    .kpi .value{ font-size: var(--fs1); font-weight: 900; letter-spacing: -.4px; margin-top: 6px; color: var(--text); }

    .kpi .sub{
      font-size: var(--fs3);
      color: var(--muted);
      margin-top: 8px;
      line-height: 1.35;
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
    }

    /* Pills (delta) */
    .delta{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding: 4px 10px;
      border-radius: 999px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.05);
      color: var(--neu);
      font-weight: 800;
      font-size: 11px;
    }
    .delta.pos{ background: rgba(34,197,94,.14); color: var(--good); border-color: rgba(34,197,94,.28); }
    .delta.neg{ background: rgba(239,68,68,.14); color: var(--bad); border-color: rgba(239,68,68,.28); }

    /* Panels / Charts */
    .panel{ padding: 14px; margin-top: 12px; }
    .panel h2{ margin: 0 0 8px 0; font-size: 14px; color: var(--text); }
    .small{ font-size: 12px; color: var(--muted); }
    .note{ margin-top: 8px; font-size: 12px; color: var(--muted); }

    .layout{ display:grid; grid-template-columns: 1fr; gap: 12px; margin-top: 12px; }
    .charts2{ display:grid; grid-template-columns: 1fr; gap: 12px; margin-top: 12px; }

    .chartBox{ position: relative; height: 240px; width: 100%; }
    .chartBox.sm{ height: 220px; }
    .chartBox.xs{ height: 190px; }

    canvas{ width: 100% !important; height: 100% !important; display:block; }

    /* Funil */
    .funnel{ display:flex; flex-direction:column; gap:10px; padding: 6px 0; }
    .step{ padding: 12px; border-radius: 16px; border: 1px solid var(--stroke); background: rgba(255,255,255,.04); }
    .step .t{ display:flex; justify-content:space-between; gap:10px; align-items:baseline; }
    .step .name{ font-size:12px; color: var(--muted); }
    .step .val{ font-size:18px; font-weight:900; letter-spacing:-.2px; color: var(--text); }
    .step .meta{ margin-top: 8px; font-size: 12px; color: var(--muted); line-height:1.25; }

    .pill{ display:inline-flex; align-items:center; gap:8px; padding: 10px 12px; border-radius: 999px; border: 1px solid var(--stroke); background: rgba(255,255,255,.05); font-size: 12px; color: var(--muted); margin-top: 10px; }
    .dot{ width: 8px; height: 8px; border-radius: 50%; background: var(--accent); display:inline-block; box-shadow: 0 0 0 3px rgba(255,122,0,.18); }

    /* Pequenos ajustes em telas muito pequenas */
    @media (max-width: 360px){
      .btn{ min-width: 112px; }
      .chartBox{ height: 220px; }
    }
  </style>
</head>
<body>
  <div class="wrap">

    <div class="topbar">
      <div class="title">
        <h1>Pop Modas Jeans</h1>
        <p id="subtitle">Carregando datas…</p>
      </div>

      <div class="controls">
        <div class="field">
          <label>Data início</label>
          <input id="start" type="date" />
        </div>
        <div class="field">
          <label>Data fim</label>
          <input id="end" type="date" />
        </div>

        <div class="row">
          <button class="btn" id="btn7">Últimos 7 dias</button>
          <button class="btn" id="btn30">Últimos 30 dias</button>
          <button class="btn" id="btnMesAtual">MesAtual (até ontem)</button>
        </div>

        <label class="switch">
          <input id="compare" type="checkbox" /> Comparar com período anterior
        </label>

        <button class="btn btn-primary" id="btnGo">Gerar</button>
      </div>
    </div>

    <div class="err" id="err"></div>

    <!-- KPIs (1 por linha) -->
    <div class="grid">
      <div class="kpi"><div class="label">Investimento (Total)</div><div class="value" id="kSpend">—</div><div class="sub" id="kSpendSub"></div></div>
      <div class="kpi"><div class="label">Receita (Paga)</div><div class="value" id="kRevenue">—</div><div class="sub" id="kRevenueSub"></div></div>
      <div class="kpi"><div class="label">Compras / Pedidos</div><div class="value" id="kPurch">—</div><div class="sub" id="kPurchSub"></div></div>
      <div class="kpi"><div class="label">ROAS (Receita ÷ Invest.)</div><div class="value" id="kRoas">—</div><div class="sub" id="kRoasSub"></div></div>
      <div class="kpi"><div class="label">CPA (Invest. ÷ Compras)</div><div class="value" id="kCpa">—</div><div class="sub" id="kCpaSub"></div></div>
      <div class="kpi"><div class="label">Ticket Médio (Receita ÷ Compras)</div><div class="value" id="kAov">—</div><div class="sub" id="kAovSub"></div></div>
      <div class="kpi"><div class="label">Mix de Investimento</div><div class="value" id="kMix">—</div><div class="sub" id="kMixSub"></div></div>
      <div class="kpi"><div class="label">Sessões / Transações</div><div class="value" id="kSessTx">—</div><div class="sub" id="kSessTxSub"></div></div>
      <div class="kpi"><div class="label">TX Conv (Transações ÷ Sessões)</div><div class="value" id="kTxConv">—</div><div class="sub" id="kTxConvSub"></div></div>
      <div class="kpi"><div class="label">Receita Não Paga</div><div class="value" id="kUnpaid">—</div><div class="sub" id="kUnpaidSub"></div></div>
      <div class="kpi"><div class="label">Cart → Checkout</div><div class="value" id="kF1">—</div><div class="sub" id="kF1Sub"></div></div>
      <div class="kpi"><div class="label">Checkout → Compra</div><div class="value" id="kF2">—</div><div class="sub" id="kF2Sub"></div></div>
    </div>

    <!-- Linha + Funil -->
    <div class="layout">
      <div class="panel">
        <h2>Diário (Investimento x Receita)</h2>
        <div class="small" id="colInfo">—</div>
        <div class="chartBox">
          <canvas id="chartLine"></canvas>
        </div>
        <div class="note" id="note"></div>
      </div>

      <div class="panel">
        <h2>Funil do período</h2>
        <div class="small" id="funnelInfo">Cart → Checkout → Info. Pagamento → Purchase</div>

        <div class="funnel">
          <div class="step">
            <div class="t"><div class="name">Cart</div><div class="val" id="fCart">—</div></div>
            <div class="meta" id="fCartMeta"></div>
          </div>
          <div class="step">
            <div class="t"><div class="name">Checkout</div><div class="val" id="fCheckout">—</div></div>
            <div class="meta" id="fCheckoutMeta"></div>
          </div>
          <div class="step">
            <div class="t"><div class="name">Info. Pagamento</div><div class="val" id="fInfo">—</div></div>
            <div class="meta" id="fInfoMeta"></div>
          </div>
          <div class="step">
            <div class="t"><div class="name">Purchase</div><div class="val" id="fPurchase">—</div></div>
            <div class="meta" id="fPurchaseMeta"></div>
          </div>
        </div>

        <div class="pill"><span class="dot"></span><span id="fSummary">—</span></div>
      </div>
    </div>

    <!-- Barras + Roscas -->
    <div class="charts2">
      <div class="panel">
        <h2>Investimento por canal (Meta x Google)</h2>
        <div class="small">Barras empilhadas (diário)</div>
        <div class="chartBox sm"><canvas id="chartBars"></canvas></div>
        <div class="note" id="barsNote"></div>
      </div>

      <div class="panel">
        <h2>Resumo visual</h2>
        <div class="small">Roscas (mix e desperdício)</div>

        <div class="charts2" style="margin-top:10px;">
          <div class="panel" style="margin-top:0; padding:10px;">
            <div class="small">Mix de investimento</div>
            <div class="chartBox xs"><canvas id="chartDonutMix"></canvas></div>
          </div>
          <div class="panel" style="margin-top:0; padding:10px;">
            <div class="small">Gasto: com compra vs sem compra</div>
            <div class="chartBox xs"><canvas id="chartDonutWaste"></canvas></div>
          </div>
        </div>

        <div class="note" id="donutNote"></div>
      </div>
    </div>

  </div>

  <script>
    // Token vem do template (DASHBOARD.GS injeta APP_TOKEN)
    // Se você não quiser token, deixe sempre string vazia no .gs.
    const APP_TOKEN = (typeof APP_TOKEN_FROM_SERVER !== 'undefined') ? String(APP_TOKEN_FROM_SERVER||'') : '';

    const $ = (id)=>document.getElementById(id);
    let cLine, cBars, cMix, cWaste;

    function brl(n){ return (Number(n)||0).toLocaleString('pt-BR',{style:'currency',currency:'BRL'}); }
    function num(n){ return (Number(n)||0).toLocaleString('pt-BR'); }
    function pct(n){ return (Number(n)||0).toLocaleString('pt-BR',{minimumFractionDigits:2, maximumFractionDigits:2}); }
    function pct100(n){ return (Number(n)||0).toLocaleString('pt-BR',{style:'percent', minimumFractionDigits:1, maximumFractionDigits:1}); }

    function showErr(msg){
      const box = $('err');
      box.style.display = msg ? 'block' : 'none';
      box.textContent = msg || '';
    }

    function setRange(startISO, endISO){ $('start').value = startISO; $('end').value = endISO; }

    function isoToday(){
      const d = new Date();
      const y = d.getFullYear();
      const m = String(d.getMonth()+1).padStart(2,'0');
      const day = String(d.getDate()).padStart(2,'0');
      return `${y}-${m}-${day}`;
    }

    function addDays(iso, delta){
      const [y,m,d] = iso.split('-').map(Number);
      const dt = new Date(y, m-1, d);
      dt.setDate(dt.getDate() + delta);
      const yy = dt.getFullYear();
      const mm = String(dt.getMonth()+1).padStart(2,'0');
      const dd = String(dt.getDate()).padStart(2,'0');
      return `${yy}-${mm}-${dd}`;
    }

    function MesAtualUntilYesterday(){
      const today = new Date();
      const y = today.getFullYear();
      const m = today.getMonth();
      const start = new Date(y, m, 1);
      const end = new Date(today);
      end.setDate(end.getDate()-1);
      if (end < start) end.setTime(start.getTime());

      const sISO = `${start.getFullYear()}-${String(start.getMonth()+1).padStart(2,'0')}-${String(start.getDate()).padStart(2,'0')}`;
      const eISO = `${end.getFullYear()}-${String(end.getMonth()+1).padStart(2,'0')}-${String(end.getDate()).padStart(2,'0')}`;
      return { sISO, eISO };
    }

    function safeDiv(a,b){ a=Number(a)||0; b=Number(b)||0; return b>0 ? (a/b) : 0; }

    function applyChartTheme(){
      const css = getComputedStyle(document.documentElement);
      const text = (css.getPropertyValue('--text')||'#fff').trim();
      const muted = (css.getPropertyValue('--muted')||'rgba(255,255,255,.66)').trim();

      Chart.defaults.color = text;
      Chart.defaults.font.family = "ui-sans-serif, -apple-system, system-ui, Segoe UI, Roboto, Arial";
      Chart.defaults.font.size = 11;
      Chart.defaults.plugins.legend.labels.color = text;
      Chart.defaults.plugins.tooltip.backgroundColor = 'rgba(10,10,14,.95)';
      Chart.defaults.plugins.tooltip.titleColor = '#fff';
      Chart.defaults.plugins.tooltip.bodyColor = '#fff';
      Chart.defaults.plugins.tooltip.borderColor = 'rgba(255,122,0,.35)';
      Chart.defaults.plugins.tooltip.borderWidth = 1;

      // defaults de escalas
      Chart.defaults.scales = Chart.defaults.scales || {};
      Chart.defaults.scales.linear = Chart.defaults.scales.linear || {};
      Chart.defaults.scales.category = Chart.defaults.scales.category || {};
      Chart.defaults.scales.linear.grid = { color: 'rgba(255,255,255,.10)' };
      Chart.defaults.scales.category.grid = { color: 'rgba(255,255,255,.10)' };
      Chart.defaults.scales.linear.ticks = { color: muted };
      Chart.defaults.scales.category.ticks = { color: muted };
    }

    function deltaPillHTML(delta, goodWhen='up', fmt='num'){
      const d = Number(delta);
      if (!isFinite(d) || d === 0) return `<span class="delta">0</span>`;

      const up = d > 0;
      const isGood = (goodWhen === 'up') ? up : !up;
      const cls = isGood ? 'pos' : 'neg';
      const arrow = up ? '▲' : '▼';

      const abs = Math.abs(d);
      let v;
      if (fmt === 'brl') v = brl(abs);
      else if (fmt === 'pct') v = pct(abs);
      else if (fmt === 'pct100') v = pct100(abs);
      else v = num(abs);

      return `<span class="delta ${cls}">${arrow} ${v}</span>`;
    }

    function setSubDelta(elId, prevValueStr, deltaValue, goodWhen, fmt){
      const el = document.getElementById(elId);
      if (!el) return;
      el.innerHTML = `Anterior: ${prevValueStr} ${deltaPillHTML(deltaValue, goodWhen, fmt)}`;
    }

    function render(data){
      showErr('');

      const cur = data.current?.kpis || {};
      const cmp = data.compare?.kpis || null;

      $('kSpend').textContent = brl(cur.spend);
      $('kRevenue').textContent = brl(cur.revenue);
      $('kPurch').textContent = num(cur.purchases);
      $('kRoas').textContent = pct(cur.roas);
      $('kCpa').textContent = brl(cur.cpa);
      $('kAov').textContent = brl(cur.aov);
      $('kUnpaid').textContent = brl(cur.unpaid);

      $('kMix').textContent = `${pct100(cur.metaShare)} Meta • ${pct100(cur.googleShare)} Google`;
      $('kMixSub').textContent = `Meta: ${brl(cur.spendMeta)} | Google: ${brl(cur.spendGoogle)}`;

      $('kSessTx').textContent = `${num(cur.sessions)} / ${num(cur.transactions)}`;
      $('kSessTxSub').textContent = `Sessões GA4 / Transações GA4`;

      $('kTxConv').textContent = pct100(cur.txConv);
      $('kTxConvSub').textContent = `No período selecionado`;

      const cart = Number(cur.cart)||0;
      const checkout = Number(cur.checkout)||0;
      const infoPay = Number(cur.infoPay)||0;
      const purch = Number(cur.purchases)||0;

      const cartToCheckout = safeDiv(checkout, cart);
      const checkoutToPurch = safeDiv(purch, checkout);

      $('kF1').textContent = pct100(cartToCheckout);
      $('kF1Sub').textContent = `Cart→Checkout (${num(checkout)} de ${num(cart)})`;
      $('kF2').textContent = pct100(checkoutToPurch);
      $('kF2Sub').textContent = `Checkout→Compra (${num(purch)} de ${num(checkout)})`;

      if (cmp){
        setSubDelta('kSpendSub', brl(cmp.spend), (cur.spend - cmp.spend), 'down', 'brl');
        setSubDelta('kRevenueSub', brl(cmp.revenue), (cur.revenue - cmp.revenue), 'up', 'brl');
        setSubDelta('kPurchSub', num(cmp.purchases), (cur.purchases - cmp.purchases), 'up', 'num');
        setSubDelta('kRoasSub', pct(cmp.roas), (cur.roas - cmp.roas), 'up', 'pct');
        setSubDelta('kCpaSub', brl(cmp.cpa), (cur.cpa - cmp.cpa), 'down', 'brl');
        setSubDelta('kAovSub', brl(cmp.aov), (cur.aov - cmp.aov), 'up', 'brl');
        setSubDelta('kUnpaidSub', brl(cmp.unpaid), (cur.unpaid - cmp.unpaid), 'down', 'brl');
        setSubDelta('kTxConvSub', pct100(cmp.txConv), (cur.txConv - cmp.txConv), 'up', 'pct100');
      }else{
        $('kSpendSub').textContent = '';
        $('kRevenueSub').textContent = '';
        $('kPurchSub').textContent = '';
        $('kRoasSub').textContent = '';
        $('kCpaSub').textContent = '';
        $('kAovSub').textContent = '';
        $('kUnpaidSub').textContent = '';
      }

      const c = data.columnsFound || {};
      $('colInfo').textContent =
        `Colunas detectadas → Data: ${c.date || '—'} | Total: ${c.spend_total || '—'} | Meta: ${c.spend_meta || '—'} | Google: ${c.spend_google || '—'} | Receita: ${c.revenue_paid || '—'} | Cart: ${c.cart || '—'} | Checkout: ${c.checkout || '—'} | Info: ${c.infoPay || '—'} | Purchase: ${c.purchases || '—'}`;

      const compareNote = data.compare ? ` • Comparando com ${data.compare.range.startISO} a ${data.compare.range.endISO}` : '';
      const extra = data.note ? ` • ${data.note}` : '';
      $('note').textContent = `Período atual: ${data.range.startISO} a ${data.range.endISO}${compareNote}${extra}`;

      // Funil
      $('fCart').textContent = num(cart);
      $('fCheckout').textContent = num(checkout);
      $('fInfo').textContent = num(infoPay);
      $('fPurchase').textContent = num(purch);

      const s1 = safeDiv(checkout, cart);
      const s2 = safeDiv(infoPay, checkout);
      const s3 = safeDiv(purch, infoPay);

      $('fCartMeta').textContent = `Base do funil.`;
      $('fCheckoutMeta').textContent = `Conversão: ${pct100(s1)} (Checkout ÷ Cart)`;
      $('fInfoMeta').textContent = `Conversão: ${pct100(s2)} (Info ÷ Checkout)`;
      $('fPurchaseMeta').textContent = `Conversão: ${pct100(s3)} (Purchase ÷ Info)`;

      const overall = safeDiv(purch, cart);
      $('fSummary').textContent = `Conversão Cart → Purchase: ${pct100(overall)}`;

      // Séries
      const labels = data.current?.series?.labels || [];
      const spend = data.current?.series?.spendSeries || [];
      const revenue = data.current?.series?.revenueSeries || [];
      const metaSpend = data.current?.series?.metaSpendSeries || [];
      const googleSpend = data.current?.series?.googleSpendSeries || [];

      applyChartTheme();

      // LINE
      const ctxL = $('chartLine').getContext('2d');
      if (cLine) cLine.destroy();
      cLine = new Chart(ctxL, {
        type: 'line',
        data: {
          labels,
          datasets: [
            { label: 'Investimento (Total)', data: spend, borderWidth: 3, tension: .25, borderColor: '#ff7a00' },
            { label: 'Receita', data: revenue, borderWidth: 3, tension: .25, borderColor: '#22c55e' },
            ...(data.compare ? [
              { label: 'Investimento (anterior)', data: data.compare.series?.spendSeries || [], borderWidth: 2, tension: .25, borderDash: [6,4], borderColor: 'rgba(255,122,0,.45)' },
              { label: 'Receita (anterior)', data: data.compare.series?.revenueSeries || [], borderWidth: 2, tension: .25, borderDash: [6,4], borderColor: 'rgba(34,197,94,.45)' }
            ] : [])
          ]
        },
        options: {
          resizeDelay: 150,
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: { legend: { display: true } },
          scales: { y: { beginAtZero: true } }
        }
      });

      // BARS
      const ctxB = $('chartBars').getContext('2d');
      if (cBars) cBars.destroy();
      cBars = new Chart(ctxB, {
        type: 'bar',
        data: {
          labels,
          datasets: [
            { label: 'Meta', data: metaSpend, borderWidth: 1, stack: 's', backgroundColor: 'rgba(255,122,0,.60)' },
            { label: 'Google', data: googleSpend, borderWidth: 1, stack: 's', backgroundColor: 'rgba(255,255,255,.20)' }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: true } },
          scales: {
            x: { stacked: true },
            y: { stacked: true, beginAtZero: true }
          }
        }
      });

      $('barsNote').textContent = `Total no período → Meta: ${brl(cur.spendMeta)} • Google: ${brl(cur.spendGoogle)} (Total: ${brl(cur.spend)})`;

      // DONUT MIX
      const ctxM = $('chartDonutMix').getContext('2d');
      if (cMix) cMix.destroy();
      cMix = new Chart(ctxM, {
        type: 'doughnut',
        data: {
          labels: ['Meta', 'Google'],
          datasets: [{
            data: [Number(cur.spendMeta)||0, Number(cur.spendGoogle)||0],
            borderWidth: 1,
            backgroundColor: ['rgba(255,122,0,.70)','rgba(255,255,255,.22)']
          }]
        },
        options: { responsive: true, maintainAspectRatio: false, cutout: '68%', plugins: { legend: { display: true } } }
      });

      // DONUT WASTE
      const ctxW = $('chartDonutWaste').getContext('2d');
      if (cWaste) cWaste.destroy();
      cWaste = new Chart(ctxW, {
        type: 'doughnut',
        data: {
          labels: ['Dias com compra', 'Dias sem compra'],
          datasets: [{
            data: [Number(cur.spendWithBuy)||0, Number(cur.spendNoBuy)||0],
            borderWidth: 1,
            backgroundColor: ['rgba(34,197,94,.70)','rgba(239,68,68,.60)']
          }]
        },
        options: { responsive: true, maintainAspectRatio: false, cutout: '68%', plugins: { legend: { display: true } } }
      });

      $('donutNote').textContent = `Gasto em dias sem compra: ${brl(cur.spendNoBuy)} • em dias com compra: ${brl(cur.spendWithBuy)}`;

      // --- Auto height para iframe (WordPress) ---
      postHeightToParent();
      setTimeout(postHeightToParent, 150);
      setTimeout(postHeightToParent, 600);
    }

    // Envia altura para o WordPress (auto-resize opcional)
    function postHeightToParent(){
      try{
        const h = Math.max(
          document.documentElement.scrollHeight || 0,
          document.body.scrollHeight || 0
        );
        if (window.parent && window.parent !== window){
          window.parent.postMessage({ type: 'aec_dash_height', height: h }, '*');
        }
      }catch(e){}
    }

    // Observa mudanças de layout e envia altura
    try{
      const ro = new ResizeObserver(()=>postHeightToParent());
      ro.observe(document.body);
    }catch(e){}

    function fetchDefaults(){
      const handler = (d)=>{
        if (!d || !d.ok) {
          $('subtitle').textContent = 'Não consegui carregar datas.';
          if (d && d.error) showErr(d.error);
          return;
        }
        $('subtitle').textContent = d.note ? d.note : 'Defina o período e clique em "Gerar".';
        setRange(d.startISO, d.endISO);
        postHeightToParent();
      };

      const fail = (err)=>{
        $('subtitle').textContent = 'Erro ao carregar.';
        showErr(String(err && err.message ? err.message : err));
      };

      // Se token estiver ativo, usa endpoints secured
      if (APP_TOKEN){
        google.script.run
          .withSuccessHandler(handler)
          .withFailureHandler(fail)
          .getDashboardDefaultsSecured(APP_TOKEN);
      } else {
        google.script.run
          .withSuccessHandler(handler)
          .withFailureHandler(fail)
          .getDashboardDefaults();
      }
    }

    function fetchReport(){
      showErr('');

      const startISO = $('start').value;
      const endISO = $('end').value;
      const compare = $('compare').checked;

      if (!startISO || !endISO){ showErr('Selecione Data início e Data fim.'); return; }
      if (endISO < startISO){ showErr('A Data fim não pode ser menor que a Data início.'); return; }

      $('btnGo').textContent = 'Gerando…';

      const ok = (res)=>{
        $('btnGo').textContent = 'Gerar';
        if (!res || !res.ok){ showErr(res && res.error ? res.error : 'Erro desconhecido.'); return; }
        render(res);
      };

      const fail = (err)=>{
        $('btnGo').textContent = 'Gerar';
        showErr(String(err && err.message ? err.message : err));
      };

      if (APP_TOKEN){
        google.script.run
          .withSuccessHandler(ok)
          .withFailureHandler(fail)
          .getReportDataSecured({ startISO, endISO, compare, token: APP_TOKEN });
      } else {
        google.script.run
          .withSuccessHandler(ok)
          .withFailureHandler(fail)
          .getReportData({ startISO, endISO, compare });
      }
    }

    $('btn7').addEventListener('click', ()=>{
      const end = $('end').value || isoToday();
      setRange(addDays(end, -6), end);
      postHeightToParent();
    });

    $('btn30').addEventListener('click', ()=>{
      const end = $('end').value || isoToday();
      setRange(addDays(end, -29), end);
      postHeightToParent();
    });

    $('btnMesAtual').addEventListener('click', ()=>{
      const { sISO, eISO } = MesAtualUntilYesterday();
      setRange(sISO, eISO);
      postHeightToParent();
    });

    $('btnGo').addEventListener('click', fetchReport);

    fetchDefaults();
  </script>
</body>
</html>
