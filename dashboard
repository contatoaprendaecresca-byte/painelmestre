/* ===================== WEBAPP (WordPress iFrame) ===================== */
function doGet(e) {
  // Token opcional: se configurado, exige ?t=TOKEN
  if (DASH_ACCESS_TOKEN) {
    const t = (e && e.parameter && e.parameter.t) ? String(e.parameter.t).trim() : '';
    if (t !== DASH_ACCESS_TOKEN) {
      return HtmlService.createHtmlOutput(
        '<!doctype html><meta charset="utf-8">' +
        '<meta name="viewport" content="width=device-width, initial-scale=1">' +
        '<title>Acesso negado</title>' +
        '<style>body{margin:0;background:#07070a;color:#fff;font-family:system-ui;padding:24px}'+
        '.card{max-width:560px;margin:0 auto;background:#101018;border:1px solid rgba(255,255,255,.10);border-radius:14px;padding:16px}'+
        'h1{margin:0 0 8px 0;font-size:16px}p{margin:0;color:rgba(255,255,255,.7)}'+
        '</style>'+
        '<div class="card"><h1>Acesso negado</h1><p>Token inválido ou ausente.</p></div>'
      ).setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
