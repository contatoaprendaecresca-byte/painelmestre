// === WEBAPP ===
function doGet(e) {
  if (DASH_ACCESS_TOKEN) {
    const t = (e && e.parameter && e.parameter.t) ? String(e.parameter.t).trim() : '';
    if (t !== DASH_ACCESS_TOKEN) {
      return HtmlService.createHtmlOutput('Acesso negado. Token inválido.');
    }
  }
  const tpl = HtmlService.createTemplateFromFile('index');
  tpl.APP_TOKEN_FROM_SERVER = DASH_ACCESS_TOKEN || '';
  return tpl.evaluate().setTitle('AEC – Relatório').setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

function showDashboard_() {
  const tpl = HtmlService.createTemplateFromFile('index');
  tpl.APP_TOKEN_FROM_SERVER = DASH_ACCESS_TOKEN || '';
  const html = tpl.evaluate().setTitle('AEC – Painel').setWidth(1100).setHeight(720);
  SpreadsheetApp.getUi().showModalDialog(html, 'AEC – Relatório por Período');
}

// === ENDPOINTS DO FRONT ===
function getDashboardDefaults() {
  const cache = _dashGetCacheFull_();
  const today = new Date();
  const y = new Date(today); y.setDate(y.getDate() - 1); y.setHours(0,0,0,0);

  if (cache) {
    const { sh, headers } = cache;
    const lastRow = sh.getLastRow();
    if (lastRow <= 1) return { ok:true, minISO:_toISODate_(y), maxISO:_toISODate_(y), startISO:_toISODate_(y), endISO:_toISODate_(y), note:'Cache vazio.' };

    const dateCol = _findColByHeader_(headers, [DASH_CFG.DATE_HEADER]);
    if (dateCol < 0) return { ok:false, error:'Coluna data não encontrada no cache.' };

    const dateVals = sh.getRange(2, dateCol + 1, lastRow - 1, 1).getValues();
    let minD=null, maxD=null;
    for (let i=0; i<dateVals.length; i++) {
      const d = _parseAnyDate_(dateVals[i][0]);
      if (!d) continue;
      if (!minD || d < minD) minD = d;
      if (!maxD || d > maxD) maxD = d;
    }
    const end = (maxD && maxD < y) ? maxD : y;
    const start = new Date(end); start.setDate(start.getDate() - 29);
    return { ok: true, minISO: _toISODate_(minD || start), maxISO: _toISODate_(end), startISO: _toISODate_(start), endISO: _toISODate_(end), note: 'Painel Assessoria' };
  }
  
  // Fallback se não tiver cache
  return { ok:true, note: 'Sem cache, verificar configuração.' }; 
}

function getReportData(payload) {
  let start = _isoToDate_(payload.startISO);
  let end = _isoToDate_(payload.endISO);
  const today = new Date();
  const y = new Date(today); y.setDate(y.getDate() - 1); y.setHours(0,0,0,0);
  if (start > y) start = new Date(y);
  if (end > y) end = new Date(y);
  start.setHours(0,0,0,0); end.setHours(23,59,59,999);

  const cache = _dashGetCacheFull_();
  if (cache) {
    const { sh, headers } = cache;
    const values = sh.getRange(2, 1, Math.max(0, sh.getLastRow()-1), sh.getLastColumn()).getValues();
    const idx = _dashResolveIdx_(headers);
    const current = _dashComputeDaily_(values, idx, start, end);
    let compare = null;
    if (payload.compare) {
      const days = Math.round((end - start)/86400000) + 1;
      const prevEnd = new Date(start); prevEnd.setDate(prevEnd.getDate() - 1); prevEnd.setHours(23,59,59,999);
      const prevStart = new Date(prevEnd); prevStart.setDate(prevStart.getDate() - (days - 1)); prevStart.setHours(0,0,0,0);
      compare = _dashComputeDaily_(values, idx, prevStart, prevEnd);
      compare.range = { startISO: _toISODate_(prevStart), endISO: _toISODate_(prevEnd) };
    }
    return { ok: true, note: 'Dados CACHE', range: { startISO: _toISODate_(start), endISO: _toISODate_(end) }, columnsFound: idx.found, current, compare };
  }
  return { ok:false, error:'Cache não encontrado. Rode DASH_CACHE_SETUP.' };
}

// === CACHE CORE ===
function DASH_CACHE_REBUILD() { return _dashCacheRebuildFull_(); }
function DASH_CACHE_SYNC() { return _dashCacheSync_(); }

function _dashGetCacheFull_(){
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName(DASH_CACHE.SHEET_DAILY);
  if (!sh || sh.getLastRow() < 2) return null;
  const headers = sh.getRange(1,1,1,sh.getLastColumn()).getValues()[0];
  return { sh, headers };
}

function _dashCacheRebuildFull_(){
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let daily = ss.getSheetByName(DASH_CACHE.SHEET_DAILY);
  if(!daily) daily = ss.insertSheet(DASH_CACHE.SHEET_DAILY);
  daily.clearContents();

  const src = ss.getSheetByName(DASH_CFG.SOURCE_SHEET_NAME);
  if(!src) return {ok:false, error:'Sem MESTRE'};
  const data = src.getDataRange().getValues();
  if(data.length < 2) return {ok:false};

  // Copia bruta
  daily.getRange(1,1,data.length, data[0].length).setValues(data);
  daily.hideSheet();
  return {ok:true, mode:'rebuild', rows: data.length};
}

function _dashCacheSync_(){
  // Implementação simplificada: chama rebuild (mais seguro para garantir dados)
  return _dashCacheRebuildFull_();
}

// === COMPUTATION HELPERS ===
function _dashResolveIdx_(headers){
  const find = (c) => _findColByHeader_(headers, c);
  const idx = {
    date: find(DASH_CFG.DATE_HEADER),
    meta: find(DASH_CFG.COL_CANDIDATES.metaSpend),
    google: find(DASH_CFG.COL_CANDIDATES.googleSpend),
    total: find(DASH_CFG.COL_CANDIDATES.totalSpend),
    cart: find(DASH_CFG.COL_CANDIDATES.cart),
    checkout: find(DASH_CFG.COL_CANDIDATES.checkout),
    infoPay: find(DASH_CFG.COL_CANDIDATES.infoPay),
    purch: find(DASH_CFG.COL_CANDIDATES.purchase),
    sess: find(DASH_CFG.COL_CANDIDATES.sessions),
    trans: find(DASH_CFG.COL_CANDIDATES.transactions),
    revPaid: find(DASH_CFG.COL_CANDIDATES.revenuePaid),
    revAny: find(DASH_CFG.COL_CANDIDATES.revenueAny),
    revUnpaid: find(DASH_CFG.COL_CANDIDATES.revenueUnpaid)
  };
  idx.found = {}; // Populate for frontend debug if needed
  return idx;
}

function _dashComputeDaily_(rows, idx, start, end){
  let sumSpend=0, sumMeta=0, sumGoogle=0, sumRev=0, sumUnpaid=0, sumPurch=0, sumCart=0, sumCheck=0, sumInfo=0, sumSess=0, sumTx=0;
  let spendBuy=0, spendNoBuy=0;
  const daily = {};

  for (let i=0; i<rows.length; i++){
    const d = _parseAnyDate_(rows[i][idx.date]);
    if (!d || d < start || d > end) continue;
    const key = _toISODate_(d);
    
    if(!daily[key]) daily[key] = {spend:0, meta:0, google:0, rev:0, purch:0};
    
    const meta = idx.meta>=0 ? _parseNumber_(rows[i][idx.meta]) : 0;
    const goog = idx.google>=0 ? _parseNumber_(rows[i][idx.google]) : 0;
    let spend = (idx.total>=0 ? _parseNumber_(rows[i][idx.total]) : (meta+goog));
    let rev = (idx.revPaid>=0 ? _parseNumber_(rows[i][idx.revPaid]) : (idx.revAny>=0 ? _parseNumber_(rows[i][idx.revAny]) : 0));
    const purch = idx.purch>=0 ? _parseNumber_(rows[i][idx.purch]) : 0;

    daily[key].spend += spend;
    daily[key].meta += meta;
    daily[key].google += goog;
    daily[key].rev += rev;
    daily[key].purch += purch;

    sumSpend+=spend; sumMeta+=meta; sumGoogle+=goog; sumRev+=rev; sumPurch+=purch;
    if(idx.revUnpaid>=0) sumUnpaid += _parseNumber_(rows[i][idx.revUnpaid]);
    if(idx.cart>=0) sumCart += _parseNumber_(rows[i][idx.cart]);
    if(idx.checkout>=0) sumCheck += _parseNumber_(rows[i][idx.checkout]);
    if(idx.infoPay>=0) sumInfo += _parseNumber_(rows[i][idx.infoPay]);
    if(idx.sess>=0) sumSess += _parseNumber_(rows[i][idx.sess]);
    if(idx.trans>=0) sumTx += _parseNumber_(rows[i][idx.trans]);
  }
  
  const labels = Object.keys(daily).sort();
  labels.forEach(k => {
    if(daily[k].purch > 0) spendBuy += daily[k].spend; else spendNoBuy += daily[k].spend;
  });

  return {
    kpis: {
      spend: sumSpend, revenue: sumRev, unpaid: sumUnpaid, purchases: sumPurch,
      roas: sumSpend?sumRev/sumSpend:0, cpa: sumPurch?sumSpend/sumPurch:0, aov: sumPurch?sumRev/sumPurch:0,
      spendMeta: sumMeta, spendGoogle: sumGoogle, metaShare: sumSpend?sumMeta/sumSpend:0, googleShare: sumSpend?sumGoogle/sumSpend:0,
      cart: sumCart, checkout: sumCheck, infoPay: sumInfo, sessions: sumSess, transactions: sumTx, txConv: sumSess?sumTx/sumSess:0,
      spendWithBuy: spendBuy, spendNoBuy: spendNoBuy
    },
    series: {
      labels,
      spendSeries: labels.map(k=>daily[k].spend),
      revenueSeries: labels.map(k=>daily[k].rev),
      metaSpendSeries: labels.map(k=>daily[k].meta),
      googleSpendSeries: labels.map(k=>daily[k].google)
    }
  };
}

// === HELPERS LOCAL DASH ===
function _findColByHeader_(headers, candidates) {
  const h = headers.map(x => String(x || '').trim().toLowerCase());
  const arr = Array.isArray(candidates) ? candidates : [candidates];
  for (const c of arr) {
    const idx = h.indexOf(String(c).trim().toLowerCase());
    if (idx >= 0) return idx;
  }
  return -1;
}
function _parseAnyDate_(v) {
  if (v instanceof Date) return new Date(v.setHours(0,0,0,0));
  if (!v) return null;
  const s = String(v).split('T')[0];
  if (/^\d{4}-\d{2}-\d{2}$/.test(s)) {
    const p = s.split('-'); return new Date(p[0], p[1]-1, p[2]);
  }
  return null; 
}
function _parseNumber_(v){
  if(typeof v === 'number') return v;
  return Number(String(v||'0').replace('.','').replace(',','.')) || 0;
}
function _isoToDate_(iso) { const p=iso.split('-'); return new Date(p[0],p[1]-1,p[2]); }
function _toISODate_(d) { return Utilities.formatDate(d, Session.getScriptTimeZone(), 'yyyy-MM-dd'); }
