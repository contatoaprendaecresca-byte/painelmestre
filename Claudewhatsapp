}

// ─── HELPERS ──────────────────────────────────────────────────────────────────

function cw_num_(v) {
  if (v === null || v === '' || v === undefined) return 0;
  if (typeof v === 'number') return isFinite(v) ? v : 0;
  let s = String(v).trim().replace(/[R$\s\u00A0]/g,'').replace(/\./g,'').replace(',','.');
  const n = Number(s);
  return isFinite(n) ? n : 0;
}

function cw_toDate_(v) {
  if (v instanceof Date) return v;
  if (typeof v === 'string') {
    const m = v.trim().match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
    if (m) return new Date(Number(m[3]), Number(m[2])-1, Number(m[1]));
  }
  return null;
}

function cw_startOfDay_(d) {
  const x = new Date(d); x.setHours(0,0,0,0); return x;
}

function cw_addDays_(d, n) {
  const x = new Date(d); x.setDate(x.getDate()+n); return cw_startOfDay_(x);
}

function cw_parseBR_(s) {
  const m = String(s||'').trim().match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (!m) return null;
  const d = new Date(Number(m[3]), Number(m[2])-1, Number(m[1]));
  return d.getDate() === Number(m[1]) ? d : null;
}

function cw_fmtYMD_(d) {
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}
