5. FORMATO WhatsApp (CRÍTICO):
   - Use *texto* para negrito (um asterisco), NUNCA **texto** (dois asteriscos) — isso não funciona no WhatsApp
   - Bullets com • ou emojis, sem hífens
   - Máximo 10 linhas de conteúdo no corpo
   - Sem parágrafos longos — frases curtas e diretas

6. PRODUTOS E REGIÕES: Mencione de forma resumida e natural no texto (ex: "o Vestido Ágatha foi destaque") — NÃO liste todos, pois as listas completas já aparecem automaticamente abaixo.

7. NÃO invente dados. Se não tiver informação, pule com naturalidade.

─────────────────────────────────────────────
ESCREVA APENAS o corpo da mensagem — sem o cabeçalho (📊 Atualização...) e sem o rodapé (Seguimos acompanhando...). Esses serão adicionados automaticamente.

ESTRUTURA OBRIGATÓRIA DO CORPO (nessa ordem):

1. Saudação curta + destaque emocional principal (1 linha)

2. Bullets — TODOS obrigatórios — SEMPRE mostre a variação vs comparativo em cada um:
• 💰 Vendas: *[valor vendas]* em [N] pedidos — [variação humana vs comparativo, ex: "crescimento de 23% em relação ao mesmo período do ano passado" ou "estável em relação ao período anterior"]
• 📣 Divulgação: investimos *[valor investido]* em anúncios e cada real trouxe *[retorno]* de volta em vendas
• 👥 Visitantes: *[número]* pessoas visitaram a loja — [variação humana, ex: "+18% a mais do que no período anterior"]
• ✅ Confirmação: *[%]%* dos pedidos foram efetivados
• 📍 Destaque: mencione 1 produto ou região naturalmente

REGRA DO COMPARATIVO: O cliente PRECISA entender se cresceu ou não. O comparativo é com o *${labelComp}*.
Sempre inclua a comparação em linguagem simples nos bullets de Vendas e Visitantes. Use frases como:
- "crescimento de X% em relação ao ${labelComp}"
- "X% acima do ${labelComp}"
- "no mesmo ritmo do ${labelComp} — base sólida"
- "um pouco abaixo do ${labelComp}, mas com [ponto positivo]"
NUNCA troque o rótulo: se o comparativo for 'mesmo período do ano passado', escreva exatamente isso. Se for 'período anterior', escreva 'período anterior'. Nunca omita.

3. Frase calorosa de encerramento (1 linha)

REGRAS FINAIS:
- O bullet Divulgação SEMPRE mostra valor investido em R$ E o retorno — nunca omita nenhum dos dois
- Use *texto* para negrito (um asterisco só), NUNCA **texto** com dois asteriscos
- Máximo 10 linhas no total
- Só bullets e frases curtas, sem parágrafos
O texto será colado num grupo de WhatsApp.`;
}

// ─── MONTAGEM FINAL DA MENSAGEM ───────────────────────────────────────────────

function cw_montar_(corpoIA, at, ant, iniAt, fimAt, iniAnt, fimAnt, produtos, regioes, tipoComp) {
  function fmtDM(d) { return `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}`; }
  function brl(n)   { return 'R$ ' + Number(n||0).toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2}); }

  const linhas = [];

  // Cabeçalho fixo (igual ao insights.gs)
  linhas.push(`📊 Atualização e Feedback - ${at.conta || 'cliente'}`);
  linhas.push('');
  const compLabel = tipoComp === 'mesmo período ano anterior' ? '📅 vs mesmo período ano anterior' : '📅 vs período anterior';
  linhas.push(`📆 ${fmtDM(iniAt)}–${fmtDM(fimAt)}   ${compLabel}: ${fmtDM(iniAnt)}–${fmtDM(fimAnt)}`);
  linhas.push('');

  // Corpo gerado pelo Claude
  linhas.push(corpoIA.trim());
  linhas.push('');

  // Top Regiões (se tiver)
  if (regioes.length) {
    linhas.push('Top regiões:');
    linhas.push('');
    regioes.slice(0, 3).forEach(r => {
      const nome = String(r.nome || '').replace(/^State of\s+/i, '').replace(/^Estado de\s+/i, '').trim();
      linhas.push(`📍 ${nome} — ${brl(r.receita)}`);
    });
    linhas.push('');
  }

  // Top Produtos (se tiver)
  if (produtos.length) {
    linhas.push('Top produtos (mais impacto):');
    linhas.push('');
    produtos.slice(0, 3).forEach(p => {
      const variacao = p.variacao ? ` (${p.variacao.replace(/\s*\/\s*/g, '/')})` : '';
      const qtd = p.qtd != null ? ` | ${Math.round(p.qtd)} un` : '';
      linhas.push(`🏷️ ${p.nome}${variacao} — ${brl(p.receita)}${qtd}`);
    });
    linhas.push('');
  }

  // Dias fortes
  const melhores = at.dias
    .filter(d => d.receitaPaga > 0)
    .sort((a, b) => b.receitaPaga - a.receitaPaga)
    .slice(0, 3);

  if (melhores.length) {
    linhas.push('Dias fortes (vendas confirmadas):');
    linhas.push('');
    melhores.forEach(d => {
      linhas.push(`✅ ${fmtDM(d.data)}: ${brl(d.receitaPaga)} | ${d.pedidosPagos} pedidos`);
    });
    linhas.push('');
  }

  // Rodapé fixo
  linhas.push('Seguimos de olho em tudo por você! Qualquer novidade a gente avisa na hora. 🤝');
  linhas.push('Estamos à disposição!');

  return linhas.join('\n');
}

// ─── LEITURA E RESUMO DO MESTRE ───────────────────────────────────────────────

function cw_lerMestre_(sh) {
  const lastRow = sh.getLastRow();
  const lastCol = sh.getLastColumn();
  if (lastRow < 2) return { headerMap: {}, rows: [] };
  const values  = sh.getRange(1, 1, lastRow, lastCol).getValues();
  // Remove espacos normais e nao-quebravelis nas pontas
  const headers = values[0].map(h => String(h || '').replace(/[\u00A0\s]+$/, '').replace(/^[\u00A0\s]+/, ''));
  const headerMap = {};
  headers.forEach((h, i) => { if (h) headerMap[h] = i; });
  return { headerMap, rows: values.slice(1) };
}

function cw_resumir_(rows, headerMap, ini, fim) {
  function idx(nomes) {
    const lista = Array.isArray(nomes) ? nomes : [nomes];
    for (const n of lista) {
      if (Object.prototype.hasOwnProperty.call(headerMap, n)) return headerMap[n];
      const norm = n.replace(/[\u00A0]/g, ' ');
      if (Object.prototype.hasOwnProperty.call(headerMap, norm)) return headerMap[norm];
    }
    return -1;
  }

  const iConta  = idx('Conta ID');
  const iData   = idx('Data');
  const iTotal  = idx(['Total (R$)', 'Invest Total (R$)', 'Investimento Total']);
  const iFb     = idx(['Facebook (R$)', 'Facebook', 'Meta (R$)', 'FB (R$)']);
  const iGads   = idx(['Google Ads (R$)', 'Google Ads', 'Google (R$)']);
  const iSess   = idx(['Sessoes GA4', 'Sessões GA4', 'Sessions GA4', 'Sessões']);
  const iTrans  = idx(['Transacoes GA4', 'Transações GA4', 'Transações']);
  const iRecP   = idx(['Receita Paga Bagy (R$)', 'Receita Paga LojaVirtual (R$)', 'Receita Paga Bagy', 'Receita Paga LojaVirtual']);
  const iPedP   = idx(['Pedidos Pagos Bagy', 'Pedidos Pagos LojaVirtual', 'Pedidos Pagos']);
  const iNaoP   = idx(['Nao Pagos Bagy', 'Não Pagos Bagy', 'Não Pagos LojaVirtual (R$)', 'Não Pagos Bagy (R$)']);

  const iniT = cw_startOfDay_(ini).getTime();
  const fimT = cw_startOfDay_(fim).getTime();

  let conta = '', invest = 0, sessoes = 0, trans = 0, recPaga = 0, pedidos = 0, naoPagos = 0;
  const dias = [];

  for (const r of rows) {
    const d = cw_toDate_(iData >= 0 ? r[iData] : null);
    if (!d) continue;
    const t = cw_startOfDay_(d).getTime();
    if (t < iniT || t > fimT) continue;

    if (!conta && iConta >= 0) conta = String(r[iConta] || '').trim();

    // Investimento: tenta Total primeiro; se vier 0, soma FB + Google diretamente
    let inv = iTotal >= 0 ? cw_num_(r[iTotal]) : 0;
    if (inv <= 0) {
      const fb   = iFb   >= 0 ? cw_num_(r[iFb])   : 0;
      const gads = iGads >= 0 ? cw_num_(r[iGads]) : 0;
      inv = fb + gads;
    }
    invest += inv;

    sessoes  += cw_num_(iSess  >= 0 ? r[iSess]  : 0);
    trans    += cw_num_(iTrans >= 0 ? r[iTrans] : 0);
    const rp  = cw_num_(iRecP  >= 0 ? r[iRecP]  : 0);
    recPaga  += rp;
    const pp  = cw_num_(iPedP  >= 0 ? r[iPedP]  : 0);
    pedidos  += pp;
    naoPagos += cw_num_(iNaoP  >= 0 ? r[iNaoP]  : 0);

    dias.push({ data: d, receitaPaga: rp, pedidosPagos: pp });
  }

  const txAprovacao = trans > 0 ? pedidos / trans : null;

  return { conta, investimento: invest, sessoes, pedidosCaptados: trans,
           receitaPaga: recPaga, pedidosPagos: pedidos, naoPagos,
           txAprovacao, dias };
}

/** Diagnostico: rode no menu para checar o mapeamento de colunas */
function cw_diagnosticar() {
  const sh = SpreadsheetApp.getActive().getSheetByName('MESTRE');
  if (!sh) { SpreadsheetApp.getUi().alert('Aba MESTRE nao encontrada.'); return; }

  const { headerMap, rows } = cw_lerMestre_(sh);
  const hoje = cw_startOfDay_(new Date());
  const ini  = cw_addDays_(hoje, -7);
  const iData = headerMap['Data'] !== undefined ? headerMap['Data'] : -1;
  let linhasNoPeriodo = 0;
  rows.forEach(r => {
    const d = cw_toDate_(iData >= 0 ? r[iData] : null);
    if (d && cw_startOfDay_(d).getTime() >= ini.getTime()) linhasNoPeriodo++;
  });

  const check = [
    ['Conta ID',       headerMap['Conta ID']],
    ['Data',           headerMap['Data']],
    ['Facebook (R$)',  headerMap['Facebook (R$)']],
    ['Google Ads (R$)',headerMap['Google Ads (R$)']],
    ['Total (R$)',     headerMap['Total (R$)']],
    ['Sessoes GA4',    headerMap['Sessoes GA4'] !== undefined ? headerMap['Sessoes GA4'] : headerMap['Sessões GA4']],
    ['Receita Paga Bagy (R$)', headerMap['Receita Paga Bagy (R$)']],
    ['Pedidos Pagos Bagy',     headerMap['Pedidos Pagos Bagy']],
  ];

  const linhas = check.map(([nome, col]) =>
    nome + ': ' + (col !== undefined ? 'col ' + (col + 1) + ' OK' : 'NAO ENCONTRADA')
  );
  linhas.push('');
  linhas.push('Linhas nos ultimos 7 dias: ' + linhasNoPeriodo);
  linhas.push('');
  linhas.push('Headers (primeiros 25):');
  linhas.push(Object.keys(headerMap).slice(0, 25).join(' | '));

  SpreadsheetApp.getUi().alert('Diagnostico ClaudeWhatsApp\n\n' + linhas.join('\n'));
}

// ─── CHAMADA À API DO CLAUDE ──────────────────────────────────────────────────

function cw_chamarClaude_(apiKey, prompt) {
  const payload = {
    model:      'claude-sonnet-4-20250514',
    max_tokens: 1200,
    messages:   [{ role: 'user', content: prompt }]
  };
  const opts = {
    method:             'post',
    contentType:        'application/json',
    headers: {
      'x-api-key':         apiKey,
      'anthropic-version': '2023-06-01'
    },
    payload:            JSON.stringify(payload),
    muteHttpExceptions: true
  };
  const resp = UrlFetchApp.fetch('https://api.anthropic.com/v1/messages', opts);
  if (resp.getResponseCode() !== 200) {
    throw new Error('Erro Claude API (' + resp.getResponseCode() + '): ' + resp.getContentText());
  }
  const json = JSON.parse(resp.getContentText());
  return (json.content && json.content[0] && json.content[0].text) || '(sem resposta)';
}

// ─── SALVAR E EXIBIR ──────────────────────────────────────────────────────────

function cw_salvar_(mensagem, conta, ini, fim, modo) {
  const ss   = SpreadsheetApp.getActive();
  const nome = 'CW_WHATSAPP_CLIENTE';
  let sh     = ss.getSheetByName(nome);
  if (!sh) {
    sh = ss.insertSheet(nome);
    sh.getRange('A1').setValue('Mensagens para clientes geradas pelo Claude').setFontWeight('bold');
    sh.setColumnWidth(1, 200);
    sh.setColumnWidth(2, 800);
    sh.setFrozenRows(1);
  }

  function fmtDM(d) { return `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}`; }

  const nextRow = sh.getLastRow() + 2;
  sh.getRange(nextRow, 1, 1, 4)
    .setValues([[`${conta} | ${fmtDM(ini)}–${fmtDM(fim)}`, `Modo: ${modo}`, new Date(), '← pronto para copiar']])
    .setFontWeight('bold')
    .setBackground('#e8f5e9');

  const msgRow = nextRow + 1;
  sh.getRange(msgRow, 1, 1, 4).merge();
  sh.getRange(msgRow, 1).setValue(mensagem).setWrap(true);
  sh.setRowHeight(msgRow, 380);
  SpreadsheetApp.flush();
}

