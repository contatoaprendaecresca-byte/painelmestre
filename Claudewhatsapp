/**
 * ClaudeWhatsApp.gs
 * Gera mensagem humanizada para o grupo do cliente via Claude AI.
 *
 * ✅ Segue a estrutura do insights.gs (comparativo de período, produtos, regiões, dias fortes)
 * ✅ Usa Claude para humanizar o texto — sem termos técnicos, tom quente e positivo
 * ✅ Resultado pronto para colar no grupo do WhatsApp
 *
 * PRÉ-REQUISITO: ClaudeConnect.gs instalado e CLAUDE_API_KEY configurada.
 *
 * ADICIONAR AO MENU (em Main.gs, dentro de onOpen, antes de root.addToUi()):
 *
 *   const mCW = ui.createMenu('💬 WhatsApp Cliente');
 *   mCW
 *     .addItem('📲 7 dias — comparativo automático',        'cw_ultimos7Dias')
 *     .addItem('📲 7 dias — vs ano anterior (YoY)',         'cw_ultimos7Dias_YoY')
 *     .addItem('📲 7 dias — vs semana anterior',            'cw_ultimos7Dias_anterior')
 *     .addSeparator()
 *     .addItem('📲 14 dias — comparativo automático',       'cw_ultimos14Dias')
 *     .addItem('📲 14 dias — vs ano anterior (YoY)',        'cw_ultimos14Dias_YoY')
 *     .addSeparator()
 *     .addItem('📲 30 dias — comparativo automático',       'cw_ultimos30Dias')
 *     .addSeparator()
 *     .addItem('📆 Período manual — automático',            'cw_periodoManual')
 *     .addItem('📆 Período manual — vs ano anterior',       'cw_periodoManual_YoY')
 *     .addItem('📆 Período manual — vs período anterior',   'cw_periodoManual_anterior')
 *     .addSeparator()
 *     .addItem('⏰ Instalar gatilho semanal (seg 07:30)',   'cw_instalarGatilho')
 *     .addItem('🧹 Remover gatilho',                        'cw_removerGatilho')
 *     .addItem('🔍 Diagnóstico de colunas',                 'cw_diagnosticar');
 *   root.addSubMenu(mCW);
 */

// ─── HANDLERS PÚBLICOS ────────────────────────────────────────────────────────
// Modo de comparação: 'auto' | 'yoy' | 'anterior'
// 'auto'     → tenta YoY primeiro; se não tiver dados, usa período anterior
// 'yoy'      → força comparação com mesmo período do ano anterior
// 'anterior' → força comparação com o período imediatamente anterior (semana/janela passada)

function cw_ultimos7Dias()          { cw_gerarPorJanela_(7,  'auto');     }
function cw_ultimos7Dias_YoY()      { cw_gerarPorJanela_(7,  'yoy');      }
function cw_ultimos7Dias_anterior() { cw_gerarPorJanela_(7,  'anterior'); }
function cw_ultimos14Dias()         { cw_gerarPorJanela_(14, 'auto');     }
function cw_ultimos14Dias_YoY()     { cw_gerarPorJanela_(14, 'yoy');      }
function cw_ultimos30Dias()         { cw_gerarPorJanela_(30, 'auto');     }

function cw_gerarPorJanela_(dias, modoComp) {
  const hoje  = cw_startOfDay_(new Date());
  const fimAt = cw_addDays_(hoje, -1);
  const iniAt = cw_addDays_(fimAt, -(dias - 1));
  // Período anterior padrão (usado se modoComp='anterior' ou como fallback)
  const fimAnt = cw_addDays_(iniAt, -1);
  const iniAnt = cw_addDays_(fimAnt, -(dias - 1));
  cw_gerarMensagem_(iniAt, fimAt, iniAnt, fimAnt, 'auto-' + dias + 'd', modoComp);
}

function cw_periodoManual() {
  cw_periodoManualComModo_('auto');
}

function cw_periodoManual_YoY() {
  cw_periodoManualComModo_('yoy');
}

function cw_periodoManual_anterior() {
  cw_periodoManualComModo_('anterior');
}

function cw_periodoManualComModo_(modoComp) {
  const ui = SpreadsheetApp.getUi();
  const resp = ui.prompt(
    '📆 Período para mensagem ao cliente',
    'Digite no formato: DD/MM/AAAA a DD/MM/AAAA\nExemplo: 07/03/2026 a 13/03/2026',
    ui.ButtonSet.OK_CANCEL
  );
  if (resp.getSelectedButton() !== ui.Button.OK) return;

  const partes = (resp.getResponseText() || '').trim().split(/\s+a\s+/i);
  if (partes.length !== 2) { ui.alert('❌ Formato inválido. Use: DD/MM/AAAA a DD/MM/AAAA'); return; }

  const iniAt = cw_parseBR_(partes[0].trim());
  const fimAt = cw_parseBR_(partes[1].trim());
  if (!iniAt || !fimAt) { ui.alert('❌ Datas inválidas.'); return; }

  const dias   = Math.round((fimAt - iniAt) / 86400000) + 1;
  const fimAnt = cw_addDays_(iniAt, -1);
  const iniAnt = cw_addDays_(fimAnt, -(dias - 1));
  cw_gerarMensagem_(iniAt, fimAt, iniAnt, fimAnt, 'manual', modoComp);
}

/** Gatilho semanal: toda segunda 07:30 */
function cw_rodarSemanalAuto() { cw_ultimos7Dias(); }

function cw_instalarGatilho() {
  cw_removerGatilho();
  ScriptApp.newTrigger('cw_rodarSemanalAuto')
    .timeBased().onWeekDay(ScriptApp.WeekDay.MONDAY).atHour(7).nearMinute(30).create();
  SpreadsheetApp.getUi().alert('⏰ Gatilho instalado: segunda-feira 07:30');
}

function cw_removerGatilho() {
  ScriptApp.getProjectTriggers()
    .filter(t => t.getHandlerFunction() === 'cw_rodarSemanalAuto')
    .forEach(t => ScriptApp.deleteTrigger(t));
}

// ─── CORE ────────────────────────────────────────────────────────────────────

function cw_gerarMensagem_(iniAt, fimAt, iniAnt, fimAnt, modo, modoComp) {
  // 1. Chave
  const apiKey = PropertiesService.getScriptProperties().getProperty('CLAUDE_API_KEY');
  if (!apiKey) {
    SpreadsheetApp.getUi().alert('❌ CLAUDE_API_KEY não encontrada em PROPRIEDADES.');
    return;
  }

  // 2. Lê MESTRE
  const ss = SpreadsheetApp.getActive();
  const sh = ss.getSheetByName('MESTRE');
  if (!sh) throw new Error('Aba MESTRE não encontrada.');

  const { headerMap, rows } = cw_lerMestre_(sh);
  const atual = cw_resumir_(rows, headerMap, iniAt, fimAt);

  // 3. Decide comparativo conforme modoComp
  //    'yoy'      → força ano anterior
  //    'anterior' → força período anterior imediato
  //    'auto'     → tenta YoY; se não tiver dados, usa anterior
  modoComp = modoComp || 'auto';

  const iniYoY = cw_addDays_(iniAt, -364);
  const fimYoY = cw_addDays_(fimAt, -364);
  const resumoYoY = cw_resumir_(rows, headerMap, iniYoY, fimYoY);
  const temYoY    = resumoYoY.receitaPaga > 0;

  let comparativo, iniComp, fimComp, tipoComp;

  if (modoComp === 'yoy' || (modoComp === 'auto' && temYoY)) {
    comparativo = temYoY ? resumoYoY : cw_resumir_(rows, headerMap, iniAnt, fimAnt);
    iniComp     = temYoY ? iniYoY : iniAnt;
    fimComp     = temYoY ? fimYoY : fimAnt;
    tipoComp    = temYoY ? 'mesmo período do ano passado' : 'período anterior';
  } else {
    // 'anterior' ou auto sem dados YoY
    comparativo = cw_resumir_(rows, headerMap, iniAnt, fimAnt);
    iniComp     = iniAnt;
    fimComp     = fimAnt;
    tipoComp    = 'período anterior';
  }

  // 4. Tenta puxar produtos e regiões do GA4
  let topProdutos = [], topRegioes = [];
  try {
    const propId = PropertiesService.getScriptProperties().getProperty('GA4_PROPERTY_ID');
    if (propId && typeof insight_ga4_topItens_ === 'function') {
      const ymdIni = cw_fmtYMD_(iniAt);
      const ymdFim = cw_fmtYMD_(fimAt);
      topProdutos = insight_ga4_topItens_(propId, ymdIni, ymdFim, 3) || [];
      topRegioes  = insight_ga4_topEstados_(propId, ymdIni, ymdFim, 3) || [];
    }
  } catch(e) {
    Logger.log('GA4 opcional — ignorado: ' + e);
  }

  // 5. Monta prompt e chama Claude
  const prompt  = cw_montarPrompt_(atual, comparativo, iniAt, fimAt, iniComp, fimComp, topProdutos, topRegioes, tipoComp);
  const raw     = cw_chamarClaude_(apiKey, prompt);

  // 6. Formata mensagem final
  const mensagem = cw_montar_(raw, atual, comparativo, iniAt, fimAt, iniComp, fimComp, topProdutos, topRegioes, tipoComp);

  // 7. Salva e exibe
  cw_salvar_(mensagem, atual.conta, iniAt, fimAt, modo);
  cw_dialogo_(mensagem);
}

// ─── PROMPT PARA O CLAUDE ─────────────────────────────────────────────────────

function cw_montarPrompt_(at, ant, iniAt, fimAt, iniAnt, fimAnt, produtos, regioes, tipoComp) {
  function fmtDM(d) { return `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}`; }
  function brl(n)   { return 'R$ ' + Number(n||0).toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2}); }
  function pct(cur, prev) {
    if (!prev || prev <= 0) return null;
    return ((cur - prev) / prev * 100).toFixed(1);
  }

  const roasAt  = at.investimento > 0 ? (at.receitaPaga / at.investimento).toFixed(1) : 'n/a';
  const roasAnt = ant.investimento > 0 ? (ant.receitaPaga / ant.investimento).toFixed(1) : 'n/a';

  const varReceita = pct(at.receitaPaga,   ant.receitaPaga);
  const varSessoes = pct(at.sessoes,        ant.sessoes);
  const varPedidos = pct(at.pedidosPagos,   ant.pedidosPagos);
  const varInvest  = pct(at.investimento,   ant.investimento);

  // Melhores dias
  const melhoresDias = at.dias
    .filter(d => d.receitaPaga > 0)
    .sort((a, b) => b.receitaPaga - a.receitaPaga)
    .slice(0, 3)
    .map(d => `${fmtDM(d.data)}: ${brl(d.receitaPaga)} — ${d.pedidosPagos} pedidos`)
    .join('\n');

  // Produtos
  const listaProdutos = produtos.length
    ? produtos.map(p => {
        const variacao = p.variacao ? ` (${p.variacao})` : '';
        const qtd = p.qtd != null ? ` | ${Math.round(p.qtd)} un` : '';
        return `${p.nome}${variacao} — ${brl(p.receita)}${qtd}`;
      }).join('\n')
    : '(sem dados de produtos neste período)';

  // Regiões
  const listaRegioes = regioes.length
    ? regioes.map(r => `${r.nome} — ${brl(r.receita)}`).join('\n')
    : '(sem dados de região neste período)';

  // Formata variação de forma humana para o prompt
  // tipoComp define o rótulo: 'mesmo período do ano passado' ou 'período anterior'
  const labelComp = tipoComp || 'período anterior';
  function varHumana(cur, prev, nomeBom, nomeMau) {
    if (prev == null || prev <= 0) return '(sem comparativo)';
    const p = ((cur - prev) / prev * 100);
    const abs = Math.abs(p).toFixed(1);
    if (p >= 5)  return `+${abs}% em relação ao ${labelComp} 📈`;
    if (p <= -5) return `-${abs}% em relação ao ${labelComp} — mas ${nomeMau}`;
    return `estável em relação ao ${labelComp}`;
  }

  return `Você é o assistente de marketing da agência Aprenda e Cresça Assessoria.
Sua tarefa é escrever uma atualização para o cliente no WhatsApp — humanizada, calorosa e positiva.

CONTEXTO:
- Agência: Aprenda e Cresça Assessoria
- Cliente: ${at.conta || 'cliente'}
- Período atual: ${fmtDM(iniAt)} a ${fmtDM(fimAt)}
- Comparando com: ${fmtDM(iniAnt)} a ${fmtDM(fimAnt)} (${tipoComp || 'período anterior'})

DADOS COM COMPARATIVO:
┌─ Vendas confirmadas:   ${brl(at.receitaPaga)}   →  ${varHumana(at.receitaPaga, ant.receitaPaga, 'crescimento sólido', 'o ticket médio está forte')}
├─ Vendas anteriores:    ${brl(ant.receitaPaga)}
├─ Pedidos confirmados:  ${at.pedidosPagos}  (anterior: ${ant.pedidosPagos})  →  ${varHumana(at.pedidosPagos, ant.pedidosPagos, 'mais pedidos', 'clientes estão voltando')}
├─ Taxa de aprovação:    ${at.txAprovacao != null ? (at.txAprovacao * 100).toFixed(0) + '%' : 'n/a'}  (anterior: ${ant.txAprovacao != null ? (ant.txAprovacao * 100).toFixed(0) + '%' : 'n/a'})
├─ Investimento:         ${brl(at.investimento)}  →  ${varHumana(at.investimento, ant.investimento, 'mais divulgação', 'investimento otimizado')}
├─ Retorno do investimento: ${roasAt}x  (anterior: ${roasAnt}x)  →  ${varHumana(parseFloat(roasAt), parseFloat(roasAnt || '0'), 'retorno melhorou', 'cada real está sendo bem usado')}
└─ Visitantes:           ${at.sessoes}  →  ${varHumana(at.sessoes, ant.sessoes, 'mais pessoas na loja', 'público engajado')}

TOP PRODUTOS DESTA SEMANA:
${listaProdutos}

TOP REGIÕES:
${listaRegioes}

DIAS MAIS FORTES:
${melhoresDias || '(sem destaque)'}

─────────────────────────────────────────────
INSTRUÇÕES DE TOM E ESTILO (siga com atenção):

1. HUMANIZE: Escreva como um parceiro de confiança falando com o dono da loja. Use "a loja", "seus clientes", "semana forte". NUNCA use: ROAS, CTR, conversão, taxa de rejeição, sessões, funil, KPI, métricas, performance.

2. SEMPRE POSITIVO: Independente do resultado, encontre o ângulo positivo. Se as vendas caíram, destaque que a base está crescendo, ou que um produto se destacou, ou que o investimento foi eficiente. Nunca diga que foi ruim, fraco ou abaixo.

