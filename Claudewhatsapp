  const html = HtmlService.createHtmlOutput(`
    <div style="font-family: Arial, sans-serif; padding: 14px;">
      <div style="font-size: 14px; font-weight: bold; margin-bottom: 8px;">
        💬 Mensagem pronta para o cliente
