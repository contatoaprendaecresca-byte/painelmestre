/* -------- PRESSETS -------- */
function insight_hojeVsOntem(){
  const hoje = insight_startOfDay_(new Date());
  const ontem = insight_addDays_(hoje, -1);
  insight_gerarComparativo_(hoje, hoje, ontem, ontem);
}

function insight_ultimos3Dias(){ insight_gerarPresetSemHoje_(3); }
function insight_ultimos7Dias(){ insight_gerarPresetSemHoje_(7); }
function insight_ultimos14Dias(){ insight_gerarPresetSemHoje_(14); }
function insight_ultimos30Dias(){ insight_gerarPresetSemHoje_(30); }

function insight_gerarPresetSemHoje_(dias){
  const hoje = insight_startOfDay_(new Date());
  const fimAtual = insight_addDays_(hoje, -1);                 // ontem
  const iniAtual = insight_addDays_(fimAtual, -(dias - 1));    // janela atual
  const fimAnt = insight_addDays_(iniAtual, -1);
  const iniAnt = insight_addDays_(fimAnt, -(dias - 1));
  insight_gerarComparativo_(iniAtual, fimAtual, iniAnt, fimAnt);
}

/* -------- PERÍODO MANUAL -------- */
function insight_periodoManual(){
  const ui = SpreadsheetApp.getUi();
  const resp = ui.prompt(
    'período manual',
    'digite no formato: dd/mm/aaaa a dd/mm/aaaa\nexemplo: 12/12/2025 a 18/12/2025',
    ui.ButtonSet.OK_CANCEL
  );
  if(resp.getSelectedButton() !== ui.Button.OK) return;

  const txt = (resp.getResponseText() || '').trim();
  const parts = txt.split(/\s+a\s+/i);
  if(parts.length !== 2){
    ui.alert('formato inválido. use: dd/mm/aaaa a dd/mm/aaaa');
    return;
  }

  const iniAtual = insight_parseBRDate_(parts[0].trim());
  const fimAtual = insight_parseBRDate_(parts[1].trim());
  if(!iniAtual || !fimAtual){
    ui.alert('datas inválidas. confira dia/mês/ano.');
    return;
  }
  if(iniAtual > fimAtual){
    ui.alert('a data inicial não pode ser maior que a final.');
    return;
  }

  // compara com janela anterior do mesmo tamanho
  const dias = insight_daysDiffInclusive_(iniAtual, fimAtual);
  const fimAnt = insight_addDays_(iniAtual, -1);
  const iniAnt = insight_addDays_(fimAnt, -(dias - 1));

  insight_gerarComparativo_(insight_startOfDay_(iniAtual), insight_startOfDay_(fimAtual),
                            insight_startOfDay_(iniAnt), insight_startOfDay_(fimAnt));
}

/* -------- GATILHO SEMANAL (SEGUNDA 06:45) -------- */
function insight_instalarGatilhoSemanal(){
  // remove duplicados antes
  insight_removerGatilhoSemanal();

  ScriptApp.newTrigger('insight_rodarSemanalAuto')
    .timeBased()
    .everyWeeks(1)
    .onWeekDay(ScriptApp.WeekDay.MONDAY)
    .atHour(6)
    .nearMinute(45)
    .create();

  SpreadsheetApp.getUi().alert('gatilho semanal instalado: segunda-feira 06:45');
}

function insight_removerGatilhoSemanal(){
  const triggers = ScriptApp.getProjectTriggers();
  let removed = 0;
  triggers.forEach(t => {
    if(t.getHandlerFunction() === 'insight_rodarSemanalAuto'){
      ScriptApp.deleteTrigger(t);
      removed++;
    }
  });
  if(removed){
    SpreadsheetApp.getUi().alert('gatilho semanal removido ('+removed+').');
  }
}

function insight_listarGatilhos(){
  const triggers = ScriptApp.getProjectTriggers()
    .filter(t => (t.getHandlerFunction() || '').indexOf('insight_') === 0)
    .map(t => `${t.getHandlerFunction()} — ${t.getEventType()}`);

  SpreadsheetApp.getUi().alert(triggers.length ? triggers.join('\n') : 'nenhum gatilho de insight encontrado.');
}

/*
  Roda toda segunda 06:45:
  - janela atual: últimos 7 dias completos até ontem (segunda a domingo)
  - janela anterior: 7 dias anteriores
*/
function insight_rodarSemanalAuto(){
  const hoje = insight_startOfDay_(new Date());
  const fimAtual = insight_addDays_(hoje, -1);        // ontem (domingo, se rodar na segunda)
  const iniAtual = insight_addDays_(fimAtual, -6);    // 7 dias
  const fimAnt = insight_addDays_(iniAtual, -1);
  const iniAnt = insight_addDays_(fimAnt, -6);
  insight_gerarComparativo_(iniAtual, fimAtual, iniAnt, fimAnt, {modoAuto: true});
}

/* ===================== CORE ===================== */
function insight_gerarComparativo_(iniAtual, fimAtual, iniAnt, fimAnt, opts){
  opts = opts || {};
  const ss = SpreadsheetApp.getActive();
  const sh = ss.getSheetByName('MESTRE');
  if(!sh) throw new Error('aba "MESTRE" não encontrada.');

  const {headerMap, rows} = insight_lerMestre_(sh);

  const atual = insight_filtrarPorPeriodo_(rows, headerMap, iniAtual, fimAtual);
  const ant   = insight_filtrarPorPeriodo_(rows, headerMap, iniAnt, fimAnt);

  const resumoAtual = insight_resumirPeriodo_(atual, headerMap);
  const resumoAnt   = insight_resumirPeriodo_(ant, headerMap);

  // GA4 (top itens / top estados) — opcional
    let ga4TopItens = [];
    let ga4TopEstados = [];
    let ga4TopPaginasProduto = [];

  try{
    const propertyId = insight_getScriptProp_('GA4_PROPERTY_ID');
    if(propertyId){
      const ymdIni = insight_formatYMD_(iniAtual);
      const ymdFim = insight_formatYMD_(fimAtual);
      ga4TopItens = insight_ga4_topItens_(propertyId, ymdIni, ymdFim, 3);
      ga4TopEstados = insight_ga4_topEstados_(propertyId, ymdIni, ymdFim, 3);
      ga4TopPaginasProduto = insight_ga4_topPaginasProduto_(propertyId, ymdIni, ymdFim, 30);

    }
  }catch(e){
    Logger.log('GA4 indisponível (ok): '+e);
  }

  const texto = insight_montarTextoWhatsApp_({
    resumoAtual, resumoAnt,
    iniAtual, fimAtual, iniAnt, fimAnt,
    ga4TopItens, ga4TopEstados,
    ga4TopPaginasProduto
  });

  insight_salvarSaida_(texto, {
    conta: resumoAtual.conta || resumoAnt.conta || '',
    iniAtual, fimAtual, iniAnt, fimAnt,
    modoAuto: !!opts.modoAuto
  });

  insight_mostrarDialogo_(texto);
}

/* ===================== LEITURA / RESUMO (MESTRE) ===================== */
function insight_lerMestre_(sh){
  const lastRow = sh.getLastRow();
  const lastCol = sh.getLastColumn();
  if(lastRow < 2) return { headerMap: {}, rows: [] };

  const values = sh.getRange(1, 1, lastRow, lastCol).getValues();
  const headers = values[0].map(h => String(h || '').trim());

  const headerMap = {};
  headers.forEach((h, i) => { if(h) headerMap[h] = i; });

  const rows = values.slice(1); // a partir da linha 2
  return { headerMap, rows };
}

function insight_filtrarPorPeriodo_(rows, headerMap, ini, fim){
  const idxData = insight_colIndex_(headerMap, 'Data');
  if(idxData === -1) throw new Error('coluna "Data" não encontrada no cabeçalho da MESTRE.');

  const iniTime = ini.getTime();
  const fimTime = fim.getTime();

  const out = [];
  for(const r of rows){
    const d = insight_toDate_(r[idxData]);
    if(!d) continue;
    const t = insight_startOfDay_(d).getTime();
    if(t >= iniTime && t <= fimTime) out.push(r);
  }

  // ordena por data (para melhores dias/anomalias)
  out.sort((a,b) => insight_startOfDay_(insight_toDate_(a[idxData])).getTime() - insight_startOfDay_(insight_toDate_(b[idxData])).getTime());
  return out;
}

function insight_resumirPeriodo_(rows, headerMap){
  const idxConta = insight_colIndex_(headerMap, 'Conta ID');
  const idxData  = insight_colIndex_(headerMap, 'Data');

  const idxInvestTotal = insight_colIndex_(headerMap, 'Total (R$)');
  const idxInvestFb    = insight_colIndex_(headerMap, 'Facebook (R$)');
  const idxInvestG     = insight_colIndex_(headerMap, 'Google Ads (R$)');

  const idxSessoes     = insight_colIndex_(headerMap, 'Sessões GA4');
  const idxReceitaCap  = insight_colIndex_(headerMap, 'Receita Captada GA4 (R$)');
  const idxTicket      = insight_colIndex_(headerMap, 'Ticket Médio (R$)');
  const idxRecPaga     = insight_colIndex_(headerMap, 'Receita Paga Bagy (R$)');
  const idxPedidosPagos= insight_colIndex_(headerMap, 'Pedidos Pagos Bagy');
  const idxTransacoes  = insight_colIndex_(headerMap, 'Transações GA4');

  let conta = '';
  let investimento = 0;
  let sessoes = 0;
  let receitaCaptada = 0;
  let receitaPaga = 0;
  let pedidosPagos = 0;
  let pedidosCaptados = 0;

  // ticket médio (preferência: receitaPaga/pedidosPagos, fallback: média da coluna)
  let somaTicket = 0;
  let cntTicket = 0;

  // por dia (para melhores dias + anomalias completas)
  const dias = []; // {date, sessoes, pedidosCaptados, pedidosPagos, receitaPaga, txAprovacaoDia}

  for(const r of rows){
    if(!conta && idxConta !== -1) conta = String(r[idxConta] || '').trim();

    const invTotal = (idxInvestTotal !== -1) ? insight_toNumberBR_(r[idxInvestTotal]) : 0;
    const invFb    = (idxInvestFb !== -1) ? insight_toNumberBR_(r[idxInvestFb]) : 0;
    const invG     = (idxInvestG !== -1) ? insight_toNumberBR_(r[idxInvestG]) : 0;
    investimento += (invTotal > 0 ? invTotal : (invFb + invG));

    const s = (idxSessoes !== -1) ? insight_toNumberBR_(r[idxSessoes]) : 0;
    sessoes += s;

    const rc = (idxReceitaCap !== -1) ? insight_toNumberBR_(r[idxReceitaCap]) : 0;
    receitaCaptada += rc;

    const rp = (idxRecPaga !== -1) ? insight_toNumberBR_(r[idxRecPaga]) : 0;
    receitaPaga += rp;

    const pp = (idxPedidosPagos !== -1) ? insight_toNumberBR_(r[idxPedidosPagos]) : 0;
    pedidosPagos += pp;

    const pc = (idxTransacoes !== -1) ? insight_toNumberBR_(r[idxTransacoes]) : 0;
    pedidosCaptados += pc;

    const tkm = (idxTicket !== -1) ? insight_toNumberBR_(r[idxTicket]) : 0;
    if(tkm > 0){ somaTicket += tkm; cntTicket++; }

    const d = (idxData !== -1) ? insight_startOfDay_(insight_toDate_(r[idxData])) : null;
    if(d){
      const txDia = (pc > 0) ? (pp / pc) : null;
      dias.push({
        date: d,
        sessoes: s,
        pedidosCaptados: pc,
        pedidosPagos: pp,
        receitaPaga: rp,
        txAprovacaoDia: txDia
      });
    }
  }

  let ticketMedio = 0;
  if(pedidosPagos > 0 && receitaPaga > 0){
    ticketMedio = receitaPaga / pedidosPagos;
  }else if(cntTicket > 0){
    ticketMedio = somaTicket / cntTicket;
  }

  const txAprovacao = (pedidosCaptados > 0 && pedidosPagos >= 0)
    ? (pedidosPagos / pedidosCaptados)
    : null;

  // melhores dias por receita paga
  const melhoresDias = dias
    .slice()
    .sort((a,b) => b.receitaPaga - a.receitaPaga)
    .filter(x => x.receitaPaga > 0)
    .slice(0, 3);

  // ===== anomalias (agressores + potencializadores) =====
  const agressores = [];
  const potencializadores = [];

  function pct(prev, cur){
    prev = Number(prev || 0);
    cur  = Number(cur  || 0);
    if(prev <= 0) return null;
    return (cur - prev) / prev;
  }

   for(let i=1;i<dias.length;i++){
    const prev = dias[i-1];
    const cur  = dias[i];

    const pSess  = pct(prev.sessoes, cur.sessoes);
    const pCap   = pct(prev.pedidosCaptados, cur.pedidosCaptados);
    const pPag   = pct(prev.pedidosPagos, cur.pedidosPagos);
    const pRecPg = pct(prev.receitaPaga, cur.receitaPaga);

    const txDia = (cur.txAprovacaoDia == null) ? null : Number(cur.txAprovacaoDia);

    const queda30 =
      (pSess  != null && pSess  <= -0.30) ||
      (pCap   != null && pCap   <= -0.30) ||
      (pPag   != null && pPag   <= -0.30) ||
      (pRecPg != null && pRecPg <= -0.30);

    const pico30 =
      (pSess  != null && pSess  >=  0.30) ||
      (pCap   != null && pCap   >=  0.30) ||
      (pPag   != null && pPag   >=  0.30) ||
      (pRecPg != null && pRecPg >=  0.30);

    // mantém a aprovação no objeto (se você quiser usar depois), mas NÃO vamos exibir no WhatsApp
    const aprovRuim = (txDia != null && txDia < 0.80);
    const aprovTop  = (txDia != null && txDia >= 0.90);

    const pack = {
      date: cur.date,
      sessoes: cur.sessoes,
      pedidosCaptados: cur.pedidosCaptados,
      pedidosPagos: cur.pedidosPagos,
      receitaPaga: cur.receitaPaga,
      txAprovacaoDia: txDia,
      pctSessoes: pSess,
      pctCaptados: pCap,
      pctPagos: pPag,
      pctReceitaPaga: pRecPg
    };

    if(queda30 || aprovRuim) agressores.push(pack);
    if(pico30 || aprovTop) potencializadores.push(pack);
  }

  const anomalias = { agressores, potencializadores };

  return {
    conta,
    investimento,
    sessoes,
    receitaCaptada,
    receitaPaga,
    pedidosCaptados,
    pedidosPagos,
    txAprovacao,
    ticketMedio,
    melhoresDias,
    anomalias
  };
}

 

function insight_montarTextoWhatsApp_(ctx){
const {
resumoAtual, resumoAnt,
iniAtual, fimAtual, iniAnt, fimAnt,
ga4TopItens, ga4TopEstados
} = ctx;
const conta = resumoAtual.conta || resumoAnt.conta || 'conta';
// variações vs período anterior
const pRecPag = insight_pctChange_(resumoAtual.receitaPaga, resumoAnt.receitaPaga);
const pInvest = insight_pctChange_(resumoAtual.investimento, resumoAnt.investimento);
const pSess = insight_pctChange_(resumoAtual.sessoes, resumoAnt.sessoes);
function fmtDM_(d){
const dd = String(d.getDate()).padStart(2,'0');
const mm = String(d.getMonth()+1).padStart(2,'0');
return `${dd}/${mm}`;
}
// formata BRL removendo NBSP (para ficar visualmente "R$ 1.234,56")
function brl_(n){
return insight_formatBRL_(n).replace(/\u00A0/g,' ');
}
function cleanRegion_(s){
s = String(s || '').trim();
s = s.replace(/^State of\s+/i, '');
s = s.replace(/^Estado de\s+/i, '');
return s;
}
function cleanVar_(v){
v = String(v || '').trim();
// normaliza "Preto / M" -> "Preto/M"
v = v.replace(/\s*\/\s*/g, '/');
return v;
}
// ROAS = Receita paga / Investimento
function roasX_(){
const inv = Number(resumoAtual.investimento || 0);
const rec = Number(resumoAtual.receitaPaga || 0);
if(inv <= 0) return 'n/a';
const r = rec / inv;
// estilo "7x" (conservador): >=2x arredonda pra baixo; <2x mantém 1 casa
if(r >= 2) return `${Math.floor(r)}x`;
const one = Math.round(r * 10) / 10;
return `${String(one).replace('.', ',')}x`;
}
const linhas = [];
linhas.push(`📊Atualização e Feedback - ${conta}`);
linhas.push(``);
linhas.push(`📆 ${fmtDM_(iniAtual)}–${fmtDM_(fimAtual)} vs ${fmtDM_(iniAnt)}–${fmtDM_(fimAnt)}`);
linhas.push(``);
linhas.push(`•⁠ ⁠Vendas confirmadas: ${brl_(resumoAtual.receitaPaga)} (${insight_formatPctSigned_(pRecPag)})`);
linhas.push(`•⁠ ⁠Pedidos confirmados: ${insight_formatInt_(resumoAtual.pedidosPagos)} | Aprovação: ${resumoAtual.txAprovacao == null ? 'n/a' : insight_formatPct_(resumoAtual.txAprovacao)}`);
linhas.push(`•⁠ ⁠Investimento em anúncios: ${brl_(resumoAtual.investimento)} (${insight_formatPctSigned_(pInvest)})`);
linhas.push(`•⁠ ⁠Roas: ${roasX_()}`);
linhas.push(`•⁠ ⁠Acessos no site: ${insight_formatInt_(resumoAtual.sessoes)} (${insight_formatPctSigned_(pSess)})`);
linhas.push(``);
// 1) TOP REGIÕES
linhas.push(`Top regiões:`);
linhas.push(``);
const regs = (ga4TopEstados || []).slice(0, 3);
if(regs.length){
regs.forEach((r, i) => {
linhas.push(`📍 ${cleanRegion_(r.nome)} — ${brl_(r.receita)}`);
if(i < regs.length - 1) linhas.push(``);
});
}else{
linhas.push(`—`);
}
linhas.push(``);
// 2) TOP PRODUTOS
linhas.push(`Top produtos (mais impacto):`);
linhas.push(``);
const itens = (ga4TopItens || []).slice(0, 3);
if(itens.length){
itens.forEach((it, i) => {
const nome = it.nome || '';
const variacao = it.variacao ? cleanVar_(it.variacao) : '';
const varTxt = variacao ? ` (${variacao})` : '';
const qtdTxt = (it.qtd != null) ? ` | ${insight_formatInt_(it.qtd)} un` : '';
linhas.push(`🏷️ ${nome}${varTxt} — ${brl_(it.receita)}${qtdTxt}`);
if(i < itens.length - 1) linhas.push(``);
});
}else{
linhas.push(`—`);
}
linhas.push(``);
// 3) DIAS FORTES (POR ÚLTIMO)
linhas.push(`Dias fortes (faturado pago):`);
linhas.push(``);
const melhores = (resumoAtual.melhoresDias || [])
.slice(0, 3)
.filter(d => (d && d.receitaPaga > 0));
if(melhores.length){
melhores.forEach((d, i) => {
linhas.push(`✅ ${fmtDM_(d.date)}: ${brl_(d.receitaPaga)} | ${insight_formatInt_(d.pedidosPagos)} pedidos`);
if(i < melhores.length - 1) linhas.push(``);
});
}else{
linhas.push(`—`);
}
linhas.push(``);
linhas.push(`Seguimos acompanhando! Em caso de (Anomalias) Avisaremos vocês o mais breve possível. `);
linhas.push(`Estamos a disposição!`);
linhas.push(``);
linhas.push(``);
return linhas.join('\n');
}




 
/* ===================== SAÍDA (SHEET + DIALOG) ===================== */
function insight_salvarSaida_(texto, meta){
  const ss = SpreadsheetApp.getActive();
  const outName = 'insight_WHATSAPP';
  let sh = ss.getSheetByName(outName);
  if(!sh) sh = ss.insertSheet(outName);

  sh.getRange('A1').setValue('insight pronto para copiar (texto abaixo)');
  sh.getRange('A2').setValue(texto);

  sh.getRange('A1').setFontWeight('bold');
  sh.getRange('A2').setWrap(true);
  sh.setColumnWidth(1, 900);
  sh.setRowHeights(2, 2, 420);

  // histórico (append)
  const row = sh.getLastRow() + 2;
  sh.getRange(row, 1).setValue('histórico');
  sh.getRange(row, 1).setFontWeight('bold');

  const headerRow = row + 1;
  sh.getRange(headerRow, 1, 1, 6).setValues([['gerado em','conta','período atual','período anterior','modo','texto']])
    .setFontWeight('bold');

  const dataRow = headerRow + 1;
  sh.getRange(dataRow, 1, 1, 6).setValues([[
    new Date(),
    meta.conta || '',
    `${insight_formatBR_(meta.iniAtual)} a ${insight_formatBR_(meta.fimAtual)}`,
    `${insight_formatBR_(meta.iniAnt)} a ${insight_formatBR_(meta.fimAnt)}`,
    meta.modoAuto ? 'automático' : 'manual/menu',
    texto
  ]]);

  sh.getRange(dataRow, 1).setNumberFormat('dd/mm/yyyy hh:mm');
  sh.getRange(dataRow, 3, 1, 2).setNumberFormat('@');
  sh.getRange(dataRow, 6).setWrap(true);

  // deixa “A2” sempre visível
  sh.setFrozenRows(1);
}

