/* ===================== GA4 (OPCIONAL) ===================== */
/*
  Este bloco tenta usar o serviço avançado "Google Analytics Data API" (AnalyticsData).
  Se sua integração atual já tem funções prontas, você pode simplesmente substituir o miolo
  de insight_ga4_runReport_() para chamar a sua função existente.
*/

function insight_ga4_topItens_(propertyId, startYmd, endYmd, limit){
  // tentativa 1: itemName + itemVariant (se sua implementação tiver cor/tamanho aqui, já vem junto)
  try{
    const res = insight_ga4_runReport_(
      propertyId, startYmd, endYmd,
      ['itemName','itemVariant'],
      ['itemRevenue','itemPurchaseQuantity'],
      limit, 'itemRevenue'
    );
    return insight_ga4_parseTopItens_(res, true);
  }catch(e1){
    // fallback: itemName
    try{
      const res2 = insight_ga4_runReport_(propertyId, startYmd, endYmd, ['itemName'], ['itemRevenue','itemPurchaseQuantity'], limit, 'itemRevenue');
      return insight_ga4_parseTopItens_(res2, false);
    }catch(e2){
      // fallback 2: purchaseRevenue/itemsPurchased
      const res3 = insight_ga4_runReport_(propertyId, startYmd, endYmd, ['itemName'], ['purchaseRevenue','itemsPurchased'], limit, 'purchaseRevenue');
      return insight_ga4_parseTopItens_(res3, false);
    }
  }
}

function insight_ga4_parseTopItens_(res, hasVariant){
  const rows = (res && res.rows) ? res.rows : [];
  const out = [];
  for(const r of rows){
    const nome = (r.dimensionValues && r.dimensionValues[0]) ? (r.dimensionValues[0].value || '') : '';
    const variacao = (hasVariant && r.dimensionValues && r.dimensionValues[1]) ? (r.dimensionValues[1].value || '') : '';
    const receita = (r.metricValues && r.metricValues[0]) ? Number(r.metricValues[0].value || 0) : 0;
    const qtd = (r.metricValues && r.metricValues[1]) ? Number(r.metricValues[1].value || 0) : null;
    if(nome) out.push({ nome, variacao: variacao || '', receita, qtd });
  }
  return out.slice(0, 3);
}


function insight_ga4_topEstados_(propertyId, startYmd, endYmd, limit){
  try{
    const res = insight_ga4_runReport_(propertyId, startYmd, endYmd, ['region'], ['purchaseRevenue'], limit, 'purchaseRevenue');
    return insight_ga4_parseTopRegioes_(res);
  }catch(e1){
    const res2 = insight_ga4_runReport_(propertyId, startYmd, endYmd, ['region'], ['totalRevenue'], limit, 'totalRevenue');
    return insight_ga4_parseTopRegioes_(res2);
  }
}

function insight_ga4_topPaginasProduto_(propertyId, startYmd, endYmd, limit){
  // Tentativa: pagePath com sessions + purchases (se sua propriedade permitir)
  // Se falhar, apenas retorna [] sem quebrar o insight.
  try{
    const res = insight_ga4_runReport_(
      propertyId, startYmd, endYmd,
      ['pagePath'],
      ['sessions','purchases'],
      String(limit || 30),
      'purchases'
    );
    const rows = (res && res.rows) ? res.rows : [];
    const out = [];

    function isProdutoPath(p){
      if(!p) return false;
      const s = String(p).toLowerCase().trim();
      if(s === '/' || s === '') return false;                   // home
      if(s.indexOf('cart') !== -1) return false;
      if(s.indexOf('carrinho') !== -1) return false;
      if(s.indexOf('checkout') !== -1) return false;
      if(s.indexOf('finalizar') !== -1) return false;
      // Heurística simples: manter paths “de produto” (ajuste se você tiver padrão específico)
      // Se não quiser heurística, remova a linha abaixo e deixe só os excludes.
      return true;
    }

    for(const r of rows){
      const path = (r.dimensionValues && r.dimensionValues[0]) ? (r.dimensionValues[0].value || '') : '';
      if(!isProdutoPath(path)) continue;

      const sessoes = (r.metricValues && r.metricValues[0]) ? Number(r.metricValues[0].value || 0) : 0;
      const purchases = (r.metricValues && r.metricValues[1]) ? Number(r.metricValues[1].value || 0) : 0;
      if(sessoes <= 0 || purchases <= 0) continue;

      out.push({
        path,
        sessoes,
        purchases,
        conversao: purchases / sessoes
      });
    }

    // ordena por conversão desc e pega top
    out.sort((a,b) => (b.conversao - a.conversao));
    return out.slice(0, 3);
  }catch(e){
    Logger.log('GA4 páginas produto indisponível (ok): '+e);
    return [];
  }
}


function insight_ga4_runReport_(propertyId, startYmd, endYmd, dimensions, metrics, limit, orderByMetric){
  if(typeof AnalyticsData === 'undefined'){
    throw new Error('serviço AnalyticsData não disponível. (se necessário: habilite em "Services" no Apps Script)');
  }

  const request = {
    dateRanges: [{ startDate: startYmd, endDate: endYmd }],
    dimensions: dimensions.map(n => ({ name: n })),
    metrics: metrics.map(n => ({ name: n })),
    limit: String(limit || 10),
    orderBys: orderByMetric ? [{ metric: { metricName: orderByMetric }, desc: true }] : undefined
  };

  return AnalyticsData.Properties.runReport(request, 'properties/' + String(propertyId).trim());
}


function insight_ga4_parseTopRegioes_(res){
  const rows = (res && res.rows) ? res.rows : [];
  const out = [];
  for(const r of rows){
    const nome = (r.dimensionValues && r.dimensionValues[0]) ? r.dimensionValues[0].value : '';
    const receita = (r.metricValues && r.metricValues[0]) ? Number(r.metricValues[0].value || 0) : 0;
    if(nome) out.push({ nome, receita });
  }
  return out.slice(0, 3);
}

/* ===================== HELPERS ===================== */
function insight_colIndex_(headerMap, name){
  return Object.prototype.hasOwnProperty.call(headerMap, name) ? headerMap[name] : -1;
}

function insight_toNumberBR_(v){
  if(v === null || v === '') return 0;
  if(typeof v === 'number') return v;
  if(v instanceof Date) return 0;

  let s = String(v).trim();

  // percent
  if(s.endsWith('%')){
    s = s.replace('%','').trim();
    s = s.replace(/\./g,'').replace(',','.');
    const n = Number(s);
    return isNaN(n) ? 0 : (n/100);
  }

  // moeda / geral pt-br
  s = s.replace(/[^\d,\-\.]/g,''); // remove R$, espaços etc
  // se vier no padrão "1.234,56"
  s = s.replace(/\./g,'').replace(',','.');
  const n = Number(s);
  return isNaN(n) ? 0 : n;
}

function insight_toDate_(v){
  if(v instanceof Date) return v;
  if(typeof v === 'string'){
    const d = insight_parseBRDate_(v);
    if(d) return d;
  }
  return null;
}

function insight_parseBRDate_(s){
  const m = String(s || '').trim().match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if(!m) return null;
  const dd = Number(m[1]), mm = Number(m[2]), yy = Number(m[3]);
  const d = new Date(yy, mm-1, dd);
  // valida
  if(d.getFullYear() !== yy || d.getMonth() !== (mm-1) || d.getDate() !== dd) return null;
  return insight_startOfDay_(d);
}

function insight_startOfDay_(d){
  const x = new Date(d);
  x.setHours(0,0,0,0);
  return x;
}

function insight_addDays_(d, n){
  const x = new Date(d);
  x.setDate(x.getDate() + n);
  return insight_startOfDay_(x);
}

function insight_daysDiffInclusive_(ini, fim){
  const a = insight_startOfDay_(ini).getTime();
  const b = insight_startOfDay_(fim).getTime();
  return Math.floor((b - a) / 86400000) + 1;
}

function insight_formatBR_(d){
  const dd = String(d.getDate()).padStart(2,'0');
  const mm = String(d.getMonth()+1).padStart(2,'0');
  const yy = d.getFullYear();
  return `${dd}/${mm}/${yy}`;
}

function insight_formatYMD_(d){
  const yy = d.getFullYear();
  const mm = String(d.getMonth()+1).padStart(2,'0');
  const dd = String(d.getDate()).padStart(2,'0');
  return `${yy}-${mm}-${dd}`;
}

function insight_formatBRL_(n){
  n = Number(n || 0);
  return n.toLocaleString('pt-BR', { style:'currency', currency:'BRL' });
}

function insight_formatInt_(n){
  n = Math.round(Number(n || 0));
  return n.toLocaleString('pt-BR');
}

function insight_pctChange_(cur, prev){
  cur = Number(cur || 0);
  prev = Number(prev || 0);
  if(prev === 0) return null;
  return (cur - prev) / prev;
}

function insight_formatPct_(pct){
  if(pct === null || pct === undefined) return 'n/a';
  const v = Number(pct);
  const s = (v*100).toLocaleString('pt-BR', { maximumFractionDigits: 1, minimumFractionDigits: 1 });
  // mantém sinal quando negativo; quando positivo pode ficar sem "+"
  return (v >= 0 ? s+'%' : s+'%');
}

function insight_formatPctSigned_(pct){
  if(pct === null || pct === undefined) return 'n/a';
  const v = Number(pct);
  const s = (v*100).toLocaleString('pt-BR', { maximumFractionDigits: 1, minimumFractionDigits: 1 }) + '%';
  return (v > 0 ? ('+' + s) : s);
}

function insight_badge_(pct){
  if(pct === null || pct === undefined) return '➖';
  if(pct <= -0.20) return '⚠️';
  if(pct >=  0.20) return '✅';
  return '➖';
}

function insight_getScriptProp_(key){
  return PropertiesService.getScriptProperties().getProperty(key);
}

function insight_escapeHtml_(s){
  return String(s || '')
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;');
}

