function insight_hojeVsOntem(){
  const hoje = insight_startOfDay_(new Date());
  const ontem = insight_addDays_(hoje, -1);
  insight_gerarComparativo_(hoje, hoje, ontem, ontem);
}

function insight_ultimos3Dias(){ insight_gerarPresetSemHoje_(3); }
function insight_ultimos7Dias(){ insight_gerarPresetSemHoje_(7); }
function insight_ultimos14Dias(){ insight_gerarPresetSemHoje_(14); }
function insight_ultimos30Dias(){ insight_gerarPresetSemHoje_(30); }

function insight_gerarPresetSemHoje_(dias){
  const hoje = insight_startOfDay_(new Date());
  const fimAtual = insight_addDays_(hoje, -1);
  const iniAtual = insight_addDays_(fimAtual, -(dias - 1));
  const fimAnt = insight_addDays_(iniAtual, -1);
  const iniAnt = insight_addDays_(fimAnt, -(dias - 1));
  insight_gerarComparativo_(iniAtual, fimAtual, iniAnt, fimAnt);
}

function insight_periodoManual(){
  const ui = SpreadsheetApp.getUi();
  const resp = ui.prompt('Período manual', 'Formato: dd/mm/aaaa a dd/mm/aaaa', ui.ButtonSet.OK_CANCEL);
  if(resp.getSelectedButton() !== ui.Button.OK) return;
  const parts = resp.getResponseText().split(/\s+a\s+/i);
  if(parts.length !== 2) return ui.alert('Formato inválido.');
  const ini = insight_parseBRDate_(parts[0]);
  const fim = insight_parseBRDate_(parts[1]);
  if(!ini || !fim) return ui.alert('Datas inválidas.');
  
  const dias = Math.floor((fim - ini)/86400000) + 1;
  const fimAnt = insight_addDays_(ini, -1);
  const iniAnt = insight_addDays_(fimAnt, -(dias - 1));
  insight_gerarComparativo_(ini, fim, iniAnt, fimAnt);
}

// === GATILHOS ===
function insight_instalarGatilhoSemanal(){
  insight_removerGatilhoSemanal();
  ScriptApp.newTrigger('insight_rodarSemanalAuto').timeBased().everyWeeks(1).onWeekDay(ScriptApp.WeekDay.MONDAY).atHour(6).nearMinute(45).create();
  SpreadsheetApp.getUi().alert('Gatilho semanal instalado.');
}

function insight_removerGatilhoSemanal(){
  ScriptApp.getProjectTriggers().forEach(t => {
    if(t.getHandlerFunction() === 'insight_rodarSemanalAuto') ScriptApp.deleteTrigger(t);
  });
}

function insight_rodarSemanalAuto(){
  const hoje = insight_startOfDay_(new Date());
  const fimAtual = insight_addDays_(hoje, -1);
  const iniAtual = insight_addDays_(fimAtual, -6);
  const fimAnt = insight_addDays_(iniAtual, -1);
  const iniAnt = insight_addDays_(fimAnt, -6);
  insight_gerarComparativo_(iniAtual, fimAtual, iniAnt, fimAnt, {modoAuto: true});
}

// === LÓGICA CORE ===
function insight_gerarComparativo_(iniAtual, fimAtual, iniAnt, fimAnt, opts){
  const ss = SpreadsheetApp.getActive();
  const sh = ss.getSheetByName('MESTRE');
  if(!sh) throw new Error('Aba MESTRE não encontrada.');

  const {headerMap, rows} = insight_lerMestre_(sh);
  const atual = insight_filtrarPorPeriodo_(rows, headerMap, iniAtual, fimAtual);
  const ant = insight_filtrarPorPeriodo_(rows, headerMap, iniAnt, fimAnt);
  const resumoAtual = insight_resumirPeriodo_(atual, headerMap);
  const resumoAnt = insight_resumirPeriodo_(ant, headerMap);

  const texto = insight_montarTextoWhatsApp_({resumoAtual, resumoAnt, iniAtual, fimAtual, iniAnt, fimAnt});
  insight_salvarSaida_(texto, {conta: resumoAtual.conta, iniAtual, fimAtual, iniAnt, fimAnt, modoAuto: opts?.modoAuto});
  insight_mostrarDialogo_(texto);
}

function insight_lerMestre_(sh){
  const vals = sh.getDataRange().getValues();
  if(vals.length < 2) return {headerMap:{}, rows:[]};
  const map = {};
  vals[0].forEach((h,i)=> {if(h) map[String(h).trim()] = i;});
  return {headerMap: map, rows: vals.slice(1)};
}

function insight_filtrarPorPeriodo_(rows, headerMap, ini, fim){
  const idx = headerMap['Data'];
  if(idx === undefined) return [];
  return rows.filter(r => {
    const d = insight_toDate_(r[idx]);
    return d && d >= ini && d <= fim;
  });
}

function insight_resumirPeriodo_(rows, map){
  let conta='', inv=0, sess=0, revCap=0, revPag=0, pedCap=0, pedPag=0;
  rows.forEach(r => {
    if(!conta && map['Conta ID']) conta = r[map['Conta ID']];
    inv += insight_toNumberBR_(r[map['Total (R$)']] || r[map['Facebook (R$)']]);
    sess += insight_toNumberBR_(r[map['Sessões GA4']]);
    revCap += insight_toNumberBR_(r[map['Receita Captada GA4 (R$)']]);
    revPag += insight_toNumberBR_(r[map['Receita Paga Bagy (R$)']]);
    pedPag += insight_toNumberBR_(r[map['Pedidos Pagos Bagy']]);
    pedCap += insight_toNumberBR_(r[map['Transações GA4']]);
  });
  return {
    conta, investimento:inv, sessoes:sess, receitaCaptada:revCap, receitaPaga:revPag,
    pedidosCaptados:pedCap, pedidosPagos:pedPag,
    ticketMedio: pedPag>0 ? revPag/pedPag : 0,
    txAprovacao: pedCap>0 ? pedPag/pedCap : 0
  };
}

// === FORMATAÇÃO E SAÍDA ===
function insight_montarTextoWhatsApp_(ctx){
  const {resumoAtual: cur, resumoAnt: prev} = ctx;
  const pct = (a,b) => (b>0 ? (a-b)/b : 0);
  const fmt = (n, m) => (m ? (n*100).toFixed(1)+'%' : n.toLocaleString('pt-BR'));
  const fmtM = (n) => n.toLocaleString('pt-BR',{style:'currency', currency:'BRL'});

  const lines = [
    `📊 *Resumo: ${cur.conta || 'Geral'}*`,
    `Período: ${insight_formatBR_(ctx.iniAtual)} a ${insight_formatBR_(ctx.fimAtual)}`,
    '',
    `• Investimento: ${fmtM(cur.investimento)} (${fmt(pct(cur.investimento, prev.investimento),1)})`,
    `• Receita Paga: ${fmtM(cur.receitaPaga)} (${fmt(pct(cur.receitaPaga, prev.receitaPaga),1)})`,
    `• ROAS: ${(cur.receitaPaga/cur.investimento).toFixed(2)}`,
    `• Pedidos Pagos: ${cur.pedidosPagos}`,
    ''
  ];
  return lines.join('\n');
}

function insight_salvarSaida_(txt, meta){
  const ss = SpreadsheetApp.getActive();
  let sh = ss.getSheetByName('insight_WHATSAPP');
  if(!sh) sh = ss.insertSheet('insight_WHATSAPP');
  sh.getRange(1,1).setValue(txt);
}

function insight_mostrarDialogo_(txt){
  const html = HtmlService.createHtmlOutput(`<textarea style="width:100%;height:300px;">${txt}</textarea>`).setWidth(400).setHeight(400);
  SpreadsheetApp.getUi().showModelessDialog(html, 'Copia aí');
}

// Helpers Locais Insights
function insight_startOfDay_(d){ const x=new Date(d); x.setHours(0,0,0,0); return x; }
function insight_addDays_(d,n){ const x=new Date(d); x.setDate(x.getDate()+n); return insight_startOfDay_(x); }
function insight_parseBRDate_(s){ const p=String(s).trim().split('/'); return p.length===3 ? new Date(p[2],p[1]-1,p[0]) : null; }
function insight_toDate_(v){ return (v instanceof Date) ? insight_startOfDay_(v) : insight_parseBRDate_(v); }
function insight_toNumberBR_(v){ if(typeof v==='number') return v; return Number(String(v).replace('.','').replace(',','.'))||0; }
function insight_formatBR_(d){ return Utilities.formatDate(d, Session.getScriptTimeZone(), 'dd/MM/yyyy'); }
